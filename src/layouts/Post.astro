---
import Base from "./Base.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  tags?: string[];
  author?: string;
  readingMinutes?: number;
  ogImage?: string;
}

const {
  title,
  description,
  date,
  updated,
  tags = [],
  author = "Waev",
  readingMinutes,
  ogImage,
} = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
---

<Base
  title={`${title} — Waev Blog`}
  description={description}
  type="article"
  publishedTime={date.toISOString()}
  image={ogImage ?? "/og-default.png"}
>
  <article class="post container container--reading">
    <a class="post-back" href="/">← All posts</a>

    <header class="post-header">
      <div class="post-meta">
        <time datetime={date.toISOString()}>{fmt(date)}</time>
        {readingMinutes && (
          <>
            <span class="footer-sep">·</span>
            <span>{readingMinutes} min read</span>
          </>
        )}
        <span class="footer-sep">·</span>
        <span>{author}</span>
      </div>
      <h1 class="post-title">{title}</h1>
      <p class="post-lead">{description}</p>
      {tags.length > 0 && (
        <div class="post-meta" style="gap: var(--sp-2);">
          {tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>

    {updated && (
      <p class="post-meta" style="margin-top: var(--sp-10);">
        Last updated {fmt(updated)}
      </p>
    )}
  </article>
</Base>
