---
import Base from "./Base.astro";
import AuthorChip from "../components/AuthorChip.astro";
import RelatedPosts from "../components/RelatedPosts.astro";
import { BYLINE_AUTHORS } from "../data/authors";

interface RelatedPost {
  id: string;
  data: { title: string; description: string };
}

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  tags?: string[];
  author?: string;
  readingMinutes?: number;
  ogImage?: string;
  faq?: { q: string; a: string }[];
  hero?: { src: string; alt: string };
  relatedPosts?: RelatedPost[];
}

const {
  title,
  description,
  date,
  updated,
  tags = [],
  author = "Waev",
  readingMinutes,
  ogImage,
  faq = [],
  hero,
  relatedPosts = [],
} = Astro.props;

// Social image precedence: explicit ogImage → hero illustration → default.
const socialImage = ogImage ?? hero?.src ?? "/og-default.png";

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });

// ── Per-post structured data (answer-engine optimization) ──
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const blogPosting = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${pageUrl}#post`,
  headline: title,
  description,
  datePublished: date.toISOString(),
  ...(updated ? { dateModified: updated.toISOString() } : {}),
  author: { "@type": "Organization", name: author, url: "https://waev.app" },
  publisher: { "@id": new URL("/#org", Astro.site).href },
  mainEntityOfPage: pageUrl,
  inLanguage: "en",
  image: new URL(socialImage, Astro.site).href,
  ...(tags.length ? { keywords: tags.join(", ") } : {}),
};
const faqPage =
  faq.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faq.map((f) => ({
          "@type": "Question",
          name: f.q,
          acceptedAnswer: { "@type": "Answer", text: f.a },
        })),
      }
    : null;

// SD-09: BreadcrumbList — Home → Post
const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Waev Blog",
      item: new URL("/", Astro.site).href,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: title,
      item: pageUrl,
    },
  ],
};

const jsonLd = [...(faqPage ? [blogPosting, faqPage] : [blogPosting]), breadcrumb];
---

<Base
  title={`${title} — Waev Blog`}
  description={description}
  type="article"
  publishedTime={date.toISOString()}
  modifiedTime={updated?.toISOString()}
  author={author}
  tags={tags}
  image={socialImage}
  jsonLd={jsonLd}
>
  <article class="post">
    <div class="container container--reading">
      <a class="post-back" href="/">← All posts</a>

      <header class="post-header">
        <div class="post-meta">
          <time datetime={date.toISOString()}>{fmt(date)}</time>
          {readingMinutes && (
            <>
              <span class="footer-sep">·</span>
              <span>{readingMinutes} min read</span>
            </>
          )}
          <span class="footer-sep">·</span>
          <span class="post-byline">
            <span class="post-byline-label">Edited by</span>
            {BYLINE_AUTHORS.map((a) => <AuthorChip author={a} />)}
          </span>
        </div>
        <h1 class="post-title">{title}</h1>
        <p class="post-lead">{description}</p>
        {tags.length > 0 && (
          <div class="post-meta" style="gap: var(--sp-2);">
            {tags.map((t) => <a href={`/tags/${t}/`} class="tag">{t}</a>)}
          </div>
        )}
      </header>
    </div>

    {hero && (
      <figure class="post-hero container">
        <img src={hero.src} alt={hero.alt} loading="eager" decoding="async" />
      </figure>
    )}

    <div class="container container--reading">
      <div class="prose">
        <slot />
      </div>

      {faq.length > 0 && (
        <section class="faq" aria-labelledby="faq-title">
          <h2 class="faq-title" id="faq-title">Frequently asked</h2>
          <dl class="faq-list">
            {faq.map((f) => (
              <div class="faq-item">
                <dt class="faq-q">{f.q}</dt>
                <dd class="faq-a">{f.a}</dd>
              </div>
            ))}
          </dl>
        </section>
      )}

      <RelatedPosts posts={relatedPosts} />

      {updated && (
        <p class="post-meta" style="margin-top: var(--sp-10);">
          Last updated {fmt(updated)}
        </p>
      )}
    </div>
  </article>
</Base>
