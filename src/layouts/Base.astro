---
import "../styles/tokens.css";
import "../styles/themes/dim.css";
import "../styles/themes/dark.css";
import "../styles/themes/light.css";
import "../styles/base.css";
import "../styles/chrome.css";
import "../styles/blog.css";

import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  /** Absolute or root-relative OG image path. */
  image?: string;
  /** "website" (index) or "article" (post). */
  type?: "website" | "article";
  /** ISO date for articles. */
  publishedTime?: string;
  /** Frontmatter tags — used to emit article:tag meta on post pages. */
  tags?: string[];
  /** Extra JSON-LD graphs (e.g. BlogPosting, FAQPage) injected by a page. */
  jsonLd?: Record<string, unknown>[];
}

const {
  title,
  description = "News, updates, and philosophy from Waev — the opinionated MeshCore analyzer.",
  image = "/og-default.png",
  type = "website",
  publishedTime,
  tags = [],
  jsonLd = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
const siteName = "Waev Blog";

// ── Structured data (post-SEO / answer-engine optimization) ──
// A stable Organization + WebSite graph on every page gives AI answer
// engines clean, machine-legible facts to cite. Pages add their own graphs
// (BlogPosting, FAQPage) via the `jsonLd` prop.
const orgId = new URL("/#org", Astro.site).href;
const org = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": orgId,
  name: "Waev",
  url: "https://waev.app",
  description:
    "Real-time analytics platform for MeshCore mesh radio networks.",
  email: "admin@waev.app",
  sameAs: ["https://github.com/Treehouse-00/waev-blog"],
};
const website = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": new URL("/#website", Astro.site).href,
  name: siteName,
  url: new URL("/", Astro.site).href,
  inLanguage: "en",
  publisher: { "@id": orgId },
};
const graphs = [org, website, ...jsonLd];
---

<!doctype html>
<html lang="en" data-theme="dim">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1b1916" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Waev Blog" href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={siteName} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {type === "article" && tags.map((t) => <meta property="article:tag" content={t} />)}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts — DM Sans / DM Mono, matching waev.app -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@300;400;500&family=Google+Sans+Code:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Theme bootstrap: apply persisted theme before paint to avoid FOUC.
         Mirrors the main app (default = dim; OS preference NOT honoured). -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("waev-theme");
          if (t === "dark" || t === "dim" || t === "light") {
            document.documentElement.setAttribute("data-theme", t);
          }
        } catch (e) {
          /* private mode — fall through to default */
        }
      })();
    </script>

    <!-- JSON-LD structured data -->
    {graphs.map((g) => (
      <script type="application/ld+json" set:html={JSON.stringify(g)} />
    ))}
  </head>
  <body>
    <div class="page">
      <Nav />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
