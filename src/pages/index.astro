---
import { getPublishedPosts } from "../lib/posts";
import Base from "../layouts/Base.astro";
import MeshField from "../components/viz/MeshField.astro";

const posts = await getPublishedPosts();
const [featured, ...rest] = posts;

// Share card: use the featured post's hero so the blog card showcases the latest post.
const ogImage = featured?.data.hero?.src ?? "/og-default.png";

// Topic clusters: tag → human label, ordered by post count
const TOPICS = [
  { tag: "signal",       label: "Signal" },
  { tag: "how-it-works", label: "How it works" },
  { tag: "operations",   label: "Operations" },
  { tag: "privacy",      label: "Privacy" },
  { tag: "resilience",   label: "Resilience" },
  { tag: "community",    label: "Community" },
  { tag: "primer",       label: "Primers" },
  { tag: "hardware",     label: "Hardware" },
];

// Count per tag for the "N posts" label on the topic bar
const tagCounts = posts.reduce<Record<string, number>>((acc, p) => {
  p.data.tags.forEach((t) => { acc[t] = (acc[t] ?? 0) + 1; });
  return acc;
}, {});

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });

// Blog schema for the index page — enumerates ALL published posts (SD-08)
const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "@id": new URL("/", Astro.site).href,
  name: "Waev Blog",
  description: "Field notes on MeshCore mesh network analytics — SNR, coverage, data ownership, and privacy-by-default for ham operators, CERT teams, and emergency networks.",
  url: new URL("/", Astro.site).href,
  inLanguage: "en",
  publisher: { "@id": new URL("/#org", Astro.site).href },
  blogPost: posts.map((p, i) => ({
    "@type": "BlogPosting",
    position: i + 1,
    headline: p.data.title,
    url: new URL(`/blog/${p.id}/`, Astro.site).href,
    datePublished: p.data.date.toISOString(),
  })),
};
---

<Base
  title="Waev Blog — MeshCore Mesh Network Analytics & Operations"
  description="Field notes on MeshCore mesh network analytics — SNR, coverage, data ownership, and privacy-by-default for ham operators, CERT teams, and emergency networks."
  image={ogImage}
  jsonLd={[blogSchema]}
>
  <div class="container">
    <header class="masthead">
      <span class="kicker">The Waev Blog</span>
      <h1 class="masthead-title">
        Field notes on<br />
        <span class="masthead-gradient">mesh intelligence.</span>
      </h1>
      <p class="masthead-subtitle">
        MeshCore analytics, SNR, coverage, data ownership, and privacy-by-default
        — for the people who run the mesh.
      </p>
    </header>

    {/* Topic browse bar */}
    <nav class="topic-bar" aria-label="Browse by topic">
      <span class="topic-bar-label">Browse:</span>
      <ul class="topic-list">
        {TOPICS.filter((t) => tagCounts[t.tag] > 0).map((t) => (
          <li>
            <a href={`/tags/${t.tag}/`} class="topic-chip">
              {t.label}
              <span class="topic-chip-count">{tagCounts[t.tag]}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    {featured && (
      <div class="featured">
        <div class="featured-body">
          <div class="featured-meta">
            <span class="featured-eyebrow">Latest</span>
            <time datetime={featured.data.date.toISOString()}>{fmt(featured.data.date)}</time>
            {featured.data.tags.slice(0, 2).map((t) => (
              <a href={`/tags/${t}/`} class="tag">{t}</a>
            ))}
          </div>
          <h2 class="featured-title">
            <a class="featured-link" href={`/blog/${featured.id}/`}>{featured.data.title}</a>
          </h2>
          <p class="featured-desc">{featured.data.description}</p>
          <span class="featured-cta">Read the post →</span>
        </div>
        <div
          class={`featured-visual${featured.data.hero ? " featured-visual--photo" : ""}`}
          aria-hidden="true"
        >
          {featured.data.hero ? (
            <img src={featured.data.hero.src} alt="" loading="eager" decoding="async" />
          ) : (
            <MeshField />
          )}
        </div>
      </div>
    )}

    {rest.length > 0 && (
      <section class="more">
        <div class="more-header">
          <h2 class="more-title">All posts</h2>
          <span class="more-count">{posts.length} total</span>
        </div>
        <ul class="post-list post-list--grid">
          {rest.map((post) => (
            <li>
              <div class="card post-card">
                {post.data.hero && (
                  <div class="post-card-cover">
                    <img src={post.data.hero.src} alt="" loading="lazy" decoding="async" />
                  </div>
                )}
                <div class="post-card-body">
                  <div class="post-card-meta">
                    <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
                    {post.data.tags.slice(0, 2).map((t) => (
                      <a href={`/tags/${t}/`} class="tag">{t}</a>
                    ))}
                  </div>
                  <h3 class="post-card-title">
                    <a class="post-card-link" href={`/blog/${post.id}/`}>{post.data.title}</a>
                  </h3>
                  <p class="post-card-desc">{post.data.description}</p>
                  <span class="post-card-more">Read →</span>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>
</Base>
