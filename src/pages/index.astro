---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import MeshField from "../components/viz/MeshField.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const [featured, ...rest] = posts;

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
---

<Base title="Waev Blog — News, updates & philosophy">
  <div class="container">
    <header class="masthead">
      <span class="kicker">The Waev Blog</span>
      <h1 class="masthead-title">
        Field notes on<br />
        <span class="masthead-gradient">mesh intelligence.</span>
      </h1>
      <p class="masthead-subtitle">
        News, updates, and the thinking behind <span class="waev-brand">Waev</span> —
        what we're building for MeshCore operators, and why.
      </p>
    </header>

    {featured && (
      <a class="featured" href={`/blog/${featured.id}/`}>
        <div class="featured-body">
          <div class="featured-meta">
            <span class="featured-eyebrow">Latest</span>
            <time datetime={featured.data.date.toISOString()}>{fmt(featured.data.date)}</time>
            {featured.data.tags.slice(0, 2).map((t) => (
              <span class="tag">{t}</span>
            ))}
          </div>
          <h2 class="featured-title">{featured.data.title}</h2>
          <p class="featured-desc">{featured.data.description}</p>
          <span class="featured-cta">Read the post →</span>
        </div>
        <div
          class={`featured-visual${featured.data.hero ? " featured-visual--photo" : ""}`}
          aria-hidden="true"
        >
          {featured.data.hero ? (
            <img src={featured.data.hero.src} alt="" loading="eager" decoding="async" />
          ) : (
            <MeshField />
          )}
        </div>
      </a>
    )}

    {rest.length > 0 && (
      <section class="more">
        <h2 class="more-title">More posts</h2>
        <ul class="post-list">
          {rest.map((post) => (
            <li>
              <a class="card post-card" href={`/blog/${post.id}/`}>
                {post.data.hero && (
                  <div class="post-card-cover">
                    <img src={post.data.hero.src} alt="" loading="lazy" decoding="async" />
                  </div>
                )}
                <div class="post-card-body">
                  <div class="post-card-meta">
                    <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
                    {post.data.tags.slice(0, 2).map((t) => (
                      <span class="tag">{t}</span>
                    ))}
                  </div>
                  <h3 class="post-card-title">{post.data.title}</h3>
                  <p class="post-card-desc">{post.data.description}</p>
                  <span class="post-card-more">Read →</span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>
</Base>
