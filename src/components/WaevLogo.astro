---
/**
 * waev wordmark + wave bars — static Astro port of the app's `WaevLogo.tsx`.
 *
 * Text  → currentColor (inherits from the nav).
 * Waves → linear-gradient(accent → accent-dark), matching `.hero-gradient`.
 *
 * `uid` namespaces the gradient/mask/clip ids so multiple instances on one
 * page never collide.
 */
interface Props {
  class?: string;
  uid?: string;
}
const { class: className = "", uid = "wl" } = Astro.props;
const id = (s: string) => `${uid}${s}`;
