---
/**
 * bench-BoardCompare — side-by-side comparison of three LoRa boards for MeshCore:
 *   Heltec V3 · Heltec V4 · RAK WisBlock 4631+19007
 * Theme-aware via CSS custom properties. Pure SVG, no client JS.
 */
---

<svg viewBox="0 0 720 280" role="img" aria-label="Side-by-side comparison of three LoRa boards for MeshCore. Heltec V3: ESP32-S3, 21 dBm TX, built-in OLED, WiFi plus BLE, no GPS. Best for: beginners and base stations. Heltec V4: ESP32-S3, 28 dBm TX, built-in OLED, WiFi plus BLE, solar input. Best for: fixed repeaters needing more TX power. RAK WisBlock 4631: nRF52840, 22 dBm TX, modular no display, BLE only, ultra-low power sleep. Best for: solar nodes and long battery life." style="width:100%;height:auto;">

  <!-- ── Heltec V3 ── -->
  <rect x="10" y="16" width="216" height="250" rx="14" style="fill: var(--surface-1); stroke: var(--text-accent);" stroke-width="1.5" />
  <text x="118" y="42" text-anchor="middle" style="fill: var(--text-accent); font-family: var(--mono); font-size: 10px; letter-spacing:0.06em;">HELTEC V3</text>
  <!-- board silhouette -->
  <rect x="76" y="52" width="84" height="52" rx="5" style="fill: none; stroke: var(--text-muted);" stroke-width="1.5" />
  <rect x="82" y="58" width="26" height="16" rx="3" style="fill: none; stroke: var(--text-muted); opacity: 0.5;" stroke-width="1" />
  <line x1="150" y1="58" x2="154" y2="52" style="stroke: var(--text-muted);" stroke-width="1.2" stroke-linecap="round" />

  <text x="118" y="124" text-anchor="middle" style="fill: var(--text); font-family: var(--font); font-size: 13px; font-weight: 700;">Heltec V3</text>
  <text x="28" y="146" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">MCU</text>
  <text x="206" y="146" text-anchor="end" style="fill: var(--text); font-family: var(--mono); font-size: 11px;">ESP32-S3</text>
  <text x="28" y="166" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">TX power</text>
  <text x="206" y="166" text-anchor="end" style="fill: var(--text); font-family: var(--mono); font-size: 11px;">21 dBm</text>
  <text x="28" y="186" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">Display</text>
  <text x="206" y="186" text-anchor="end" style="fill: var(--text); font-family: var(--mono); font-size: 11px;">0.96&quot; OLED</text>
  <text x="28" y="206" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">Wireless</text>
  <text x="206" y="206" text-anchor="end" style="fill: var(--text); font-family: var(--mono); font-size: 11px;">WiFi + BLE</text>
  <text x="28" y="226" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">Sleep current</text>
  <text x="206" y="226" text-anchor="end" style="fill: var(--text); font-family: var(--mono); font-size: 11px;">15 µA (VBAT)</text>
  <rect x="22" y="240" width="192" height="18" rx="5" style="fill: var(--accent-subtle); stroke: var(--accent); opacity: 0.8;" stroke-width="1" />
  <text x="118" y="253" text-anchor="middle" style="fill: var(--text-accent); font-family: var(--font); font-size: 10px;">Best: beginners + base stations</text>

  <!-- ── Heltec V4 ── -->
  <rect x="252" y="16" width="216" height="250" rx="14" style="fill: var(--surface-1); stroke: var(--border-subtle);" stroke-width="1.25" />
  <text x="360" y="42" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--mono); font-size: 10px; letter-spacing:0.06em;">HELTEC V4</text>
  <rect x="318" y="52" width="84" height="52" rx="5" style="fill: none; stroke: var(--text-muted);" stroke-width="1.5" />
  <rect x="324" y="58" width="26" height="16" rx="3" style="fill: none; stroke: var(--text-muted); opacity: 0.5;" stroke-width="1" />
  <line x1="392" y1="58" x2="396" y2="52" style="stroke: var(--text-muted);" stroke-width="1.2" stroke-linecap="round" />
  <!-- solar icon on V4 -->
  <circle cx="398" cy="72" r="5" fill="none" style="stroke: var(--text-muted); opacity: 0.6;" stroke-width="1.2" />
  <line x1="398" y1="65" x2="398" y2="62" style="stroke: var(--text-muted); opacity: 0.5;" stroke-width="1" />
  <line x1="398" y1="79" x2="398" y2="82" style="stroke: var(--text-muted); opacity: 0.5;" stroke-width="1" />

  <text x="360" y="124" text-anchor="middle" style="fill: var(--text); font-family: var(--font); font-size: 13px; font-weight: 700;">Heltec V4</text>
  <text x="270" y="146" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">MCU</text>
  <text x="448" y="146" text-anchor="end" style="fill: var(--text); font-family: var(--mono); font-size: 11px;">ESP32-S3R2</text>
  <text x="270" y="166" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">TX power</text>
  <text x="448" y="166" text-anchor="end" style="fill: var(--text); font-family: var(--mono); font-size: 11px; font-weight: 700;">28 dBm</text>
  <text x="270" y="186" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">Display</text>
  <text x="448" y="186" text-anchor="end" style="fill: var(--text); font-family: var(--mono); font-size: 11px;">0.96&quot; OLED</text>
  <text x="270" y="206" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">Wireless</text>
  <text x="448" y="206" text-anchor="end" style="fill: var(--text); font-family: var(--mono); font-size: 11px;">WiFi + BLE</text>
  <text x="270" y="226" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">Solar input</text>
  <text x="448" y="226" text-anchor="end" style="fill: var(--text); font-family: var(--mono); font-size: 11px; font-weight: 700;">Yes</text>
  <rect x="264" y="240" width="192" height="18" rx="5" style="fill: var(--surface-sunken);" />
  <text x="360" y="253" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--font); font-size: 10px;">Best: fixed repeaters (high TX)</text>

  <!-- ── RAK WisBlock 4631 ── -->
  <rect x="494" y="16" width="216" height="250" rx="14" style="fill: var(--surface-1); stroke: var(--border-subtle);" stroke-width="1.25" />
  <text x="602" y="42" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--mono); font-size: 10px; letter-spacing:0.06em;">RAK WISBLOCK 4631</text>
  <rect x="560" y="52" width="84" height="52" rx="5" style="fill: none; stroke: var(--text-muted);" stroke-width="1.5" stroke-dasharray="4 3" />
  <!-- module cutout icon -->
  <rect x="572" y="64" width="28" height="20" rx="3" style="fill: none; stroke: var(--text-muted); opacity: 0.6;" stroke-width="1.2" />
  <text x="586" y="78" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--mono); font-size: 7px; opacity: 0.7;">4631</text>

  <text x="602" y="124" text-anchor="middle" style="fill: var(--text); font-family: var(--font); font-size: 13px; font-weight: 700;">RAK 4631</text>
  <text x="512" y="146" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">MCU</text>
  <text x="700" y="146" text-anchor="end" style="fill: var(--text); font-family: var(--mono); font-size: 11px;">nRF52840</text>
  <text x="512" y="166" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">TX power</text>
  <text x="700" y="166" text-anchor="end" style="fill: var(--text); font-family: var(--mono); font-size: 11px;">22 dBm</text>
  <text x="512" y="186" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">Display</text>
  <text x="700" y="186" text-anchor="end" style="fill: var(--text); font-family: var(--mono); font-size: 11px;">none (modular)</text>
  <text x="512" y="206" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">Wireless</text>
  <text x="700" y="206" text-anchor="end" style="fill: var(--text); font-family: var(--mono); font-size: 11px;">BLE only</text>
  <text x="512" y="226" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">Sleep current</text>
  <text x="700" y="226" text-anchor="end" style="fill: var(--text); font-family: var(--mono); font-size: 11px; font-weight: 700;">&lt; 10 µA</text>
  <rect x="506" y="240" width="192" height="18" rx="5" style="fill: var(--surface-sunken);" />
  <text x="602" y="253" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--font); font-size: 10px;">Best: solar nodes + low power</text>
</svg>
