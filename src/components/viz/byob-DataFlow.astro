---
/**
 * byob-DataFlow — data lineage for the BYOB model.
 * Shows the three-tier chain: Observer → Your Broker (canonical) → Waev (derived copy).
 * Labels each tier with what it is and who owns it.
 * Emphasizes: your broker is the canonical store; Waev's copy is derived and read-only.
 * Theme-aware via CSS custom properties.
 */
---

<svg viewBox="0 0 720 200" role="img" aria-label="Data lineage in the BYOB model. Observer publishes to your broker, which is the canonical data store you own. Waev subscribes and maintains a derived read-only copy for analytics. The canonical copy stays with the operator." style="width:100%;height:auto;">
  <defs>
    <marker id="byob-df-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
      <path d="M0 0L10 5L0 10z" style="fill: var(--border-hover);" />
    </marker>
    <marker id="byob-df-arrow-acc" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
      <path d="M0 0L10 5L0 10z" style="fill: var(--accent-light);" />
    </marker>
  </defs>

  <!-- Tier 1: Observer -->
  <rect x="20" y="40" width="148" height="100" rx="12"
    style="fill: var(--surface-1); stroke: var(--text-accent);"
    stroke-width="1.5" />
  <!-- Observer icon (small antenna) -->
  <rect x="82" y="56" width="24" height="16" rx="3"
    style="fill: none; stroke: var(--text-accent);" stroke-width="1.5" />
  <line x1="94" y1="56" x2="94" y2="49" style="stroke: var(--text-accent);" stroke-width="1.5" stroke-linecap="round" />
  <circle cx="94" cy="47" r="2.5" style="fill: var(--text-accent);" />
  <text x="94" y="90" text-anchor="middle"
    style="fill: var(--text); font-family: var(--font); font-size: 12px; font-weight: 600;">Observer</text>
  <text x="94" y="106" text-anchor="middle" class="viz-label">enrolled · active</text>
  <text x="94" y="122" text-anchor="middle" class="viz-label" style="fill: var(--text-accent);">set up by you</text>

  <!-- Arrow 1→2: publish -->
  <line x1="168" y1="90" x2="228" y2="90" style="stroke: var(--border-hover);" stroke-width="1.75" marker-end="url(#byob-df-arrow)" />
  <text x="198" y="82" text-anchor="middle" class="viz-label">publish</text>

  <!-- Tier 2: Your Broker (canonical — centered, highlighted) -->
  <rect x="238" y="24" width="200" height="132" rx="14"
    style="fill: var(--surface-1); stroke: var(--border-accent);"
    stroke-width="2" />
  <text x="338" y="46" text-anchor="middle" class="viz-label"
    style="fill: var(--text-accent); letter-spacing: 0.06em; font-size: 10px;">CANONICAL COPY</text>
  <!-- Server rack icon -->
  <g transform="translate(314, 52)" style="stroke: var(--accent-light); fill: none;" stroke-width="1.75">
    <rect x="0" y="0" width="48" height="14" rx="3" />
    <rect x="0" y="20" width="48" height="14" rx="3" />
    <circle cx="7" cy="7" r="2" style="fill: var(--accent-light); stroke: none;" />
    <circle cx="7" cy="27" r="2" style="fill: var(--accent-light); stroke: none;" />
  </g>
  <text x="338" y="100" text-anchor="middle"
    style="fill: var(--text); font-family: var(--font); font-size: 13px; font-weight: 600;">Your Broker</text>
  <text x="338" y="116" text-anchor="middle" class="viz-label">MQTT · you host it</text>
  <line x1="258" y1="132" x2="418" y2="132" style="stroke: var(--border-subtle);" stroke-width="0.8" />
  <text x="338" y="148" text-anchor="middle" style="fill: var(--accent-light); font-family: var(--mono); font-size: 11px;">you own the data ✓</text>

  <!-- Arrow 2→3: subscribe (dashed, accent) -->
  <line x1="438" y1="90" x2="498" y2="90" style="stroke: var(--accent-light); stroke-dasharray: 5 4;" stroke-width="1.75" marker-end="url(#byob-df-arrow-acc)" />
  <text x="468" y="82" text-anchor="middle" class="viz-label" style="fill: var(--text-accent);">subscribe</text>
  <text x="468" y="98" text-anchor="middle" class="viz-label" style="font-size: 10px;">read-only</text>

  <!-- Tier 3: Waev (derived copy) -->
  <rect x="508" y="40" width="192" height="100" rx="12"
    style="fill: var(--surface-1); stroke: var(--border-subtle);"
    stroke-width="1" />
  <text x="604" y="72" text-anchor="middle"
    style="fill: var(--text); font-family: var(--font); font-size: 13px; font-weight: 600;">Waev</text>
  <text x="604" y="90" text-anchor="middle" class="viz-label">derived copy · analytics</text>
  <line x1="528" y1="104" x2="680" y2="104" style="stroke: var(--border-subtle);" stroke-width="0.8" />
  <text x="604" y="120" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--mono); font-size: 11px;">map · stats · search</text>

  <!-- Ownership labels under tiers -->
  <text x="94" y="178" text-anchor="middle" class="viz-label">you operate it</text>
  <text x="338" y="178" text-anchor="middle" class="viz-label" style="fill: var(--accent-light); font-weight: 600;">you own the canonical data</text>
  <text x="604" y="178" text-anchor="middle" class="viz-label">a copy, not the keys</text>
</svg>
