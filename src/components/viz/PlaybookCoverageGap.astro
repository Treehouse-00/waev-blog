---
/**
 * PlaybookCoverageGap — abstract Live Map showing three zones:
 *   OBSERVED: backbone nodes with solid edges and healthy SNR labels.
 *   EDGE:     one intermittent node barely holding a weak path.
 *   SILENT:   an area with no recorded packets — gap or missing observer.
 * Theme-aware via CSS custom properties.
 */
---

<svg viewBox="0 0 720 280" role="img" aria-label="Live Map showing three coverage zones: a well-connected backbone cluster on the left, a weakly-connected edge node in the middle, and a silent zone on the right where no packets have been recorded." style="width:100%;height:auto;">
  <defs>
    <marker id="pb-arrow-dim" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M0 0L10 5L0 10z" style="fill: var(--border-hover);" />
    </marker>
  </defs>

  <!-- ── Zone labels ── -->
  <text x="110" y="26" text-anchor="middle" class="viz-label" style="fill: var(--text-accent); letter-spacing:0.06em;">OBSERVED</text>
  <text x="400" y="26" text-anchor="middle" class="viz-label" style="fill: var(--text-muted); letter-spacing:0.06em;">EDGE</text>
  <text x="608" y="26" text-anchor="middle" class="viz-label" style="fill: var(--text-muted); letter-spacing:0.06em;">SILENT</text>

  <!-- ── Backbone edges (draw first, behind nodes) ── -->
  <line x1="90" y1="115" x2="195" y2="65" style="stroke: var(--accent-light);" stroke-width="1.75" />
  <line x1="90" y1="115" x2="185" y2="185" style="stroke: var(--accent-light);" stroke-width="1.75" />
  <line x1="195" y1="65" x2="185" y2="185" style="stroke: var(--accent-light);" stroke-width="1.75" />

  <!-- SNR annotations on edges -->
  <text x="128" y="73" class="viz-label" style="fill: var(--text-accent);">+11 dB</text>
  <text x="104" y="162" class="viz-label" style="fill: var(--text-accent);">+9 dB</text>
  <text x="196" y="132" class="viz-label" style="fill: var(--text-accent);">+8 dB</text>

  <!-- ── Backbone nodes ── -->
  <!-- relay-main -->
  <circle cx="90" cy="115" r="13" style="fill: var(--accent);" />
  <text x="90" y="143" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">relay-main</text>
  <!-- relay-north -->
  <rect x="184" y="53" width="22" height="22" rx="5" style="fill: var(--text-accent);" />
  <text x="195" y="92" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">relay-north</text>
  <!-- relay-south -->
  <circle cx="185" cy="185" r="11" style="fill: var(--text-accent);" />
  <text x="185" y="208" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">relay-south</text>

  <!-- Observer indicator -->
  <g transform="translate(62 230)">
    <circle cx="0" cy="0" r="5" style="fill: var(--accent);" />
    <text x="12" y="4" class="viz-label" style="fill: var(--text-muted);">2 enrolled observers</text>
  </g>

  <!-- ── Observer boundary ── -->
  <line x1="300" y1="42" x2="300" y2="252" style="stroke: var(--sys-bluepurple-500); opacity: 0.5;" stroke-width="1.5" stroke-dasharray="5 6" />
  <text x="300" y="38" text-anchor="middle" class="viz-label" style="fill: var(--text-accent);">observer boundary</text>

  <!-- ── Weak edge to edge node ── -->
  <line x1="196" y1="65" x2="384" y2="112" style="stroke: var(--text-tertiary);" stroke-width="1.25" stroke-dasharray="5 4" />
  <!-- edge label -->
  <text x="290" y="80" class="viz-label" style="fill: var(--text-muted);">3 hops · +2 dB</text>

  <!-- ── Edge node (intermittent) ── -->
  <circle cx="393" cy="118" r="11" fill="none" style="stroke: var(--text-tertiary);" stroke-width="1.5" stroke-dasharray="3 3" />
  <text x="393" y="144" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">relay-ridge</text>
  <!-- warning dot -->
  <circle cx="404" cy="109" r="5" style="fill: var(--sys-orangeyellow-600);" />
  <text x="404" y="112" text-anchor="middle" style="font-family: var(--mono); font-size: 10px; fill: #000; font-weight: 700;">!</text>

  <!-- ── Dotted trace toward silent zone ── -->
  <line x1="404" y1="118" x2="538" y2="138" style="stroke: var(--border-hover);" stroke-width="1" stroke-dasharray="2 5" marker-end="url(#pb-arrow-dim)" />

  <!-- ── Silent zone ── -->
  <circle cx="600" cy="148" r="62" style="fill: var(--surface-sunken); stroke: var(--border-hover);" stroke-width="1.5" stroke-dasharray="6 5" />
  <text x="600" y="143" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">silent zone</text>
  <text x="600" y="161" text-anchor="middle" style="font-family: var(--mono); font-size: 10px; fill: var(--text-muted);">0 packets · 24 h</text>
</svg>
