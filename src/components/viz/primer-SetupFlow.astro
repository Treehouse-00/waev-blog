---
/**
 * primer-SetupFlow — four-step first-light setup flow:
 *   Flash · Configure · Power On · Confirm Link
 * Theme-aware via CSS custom properties. Pure SVG, no client JS.
 */
---

<svg viewBox="0 0 720 160" role="img" aria-label="Four-step MeshCore setup flow: Step 1 Flash firmware using the web flasher. Step 2 Configure name and radio settings via config.meshcore.io. Step 3 Power on both nodes. Step 4 Confirm the link — watch for SNR readings in the companion app." style="width:100%;height:auto;">
  <defs>
    <marker id="sf-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M0 0L10 5L0 10z" style="fill: var(--border-hover);" />
    </marker>
  </defs>

  <!-- Step 1: Flash -->
  <rect x="10" y="20" width="148" height="120" rx="12" style="fill: var(--surface-1); stroke: var(--text-accent);" stroke-width="1.5" />
  <text x="84" y="44" text-anchor="middle" style="fill: var(--text-accent); font-family: var(--mono); font-size: 10px; letter-spacing: 0.06em;">01</text>
  <!-- board + USB icon -->
  <rect x="60" y="52" width="48" height="28" rx="4" style="fill: none; stroke: var(--text-muted);" stroke-width="1.5" />
  <rect x="80" y="80" width="8" height="10" rx="2" style="fill: none; stroke: var(--text-muted);" stroke-width="1.5" />
  <line x1="84" y1="90" x2="84" y2="96" style="stroke: var(--text-muted);" stroke-width="1.5" stroke-linecap="round" />
  <text x="84" y="116" text-anchor="middle" style="fill: var(--text); font-family: var(--font); font-size: 12px; font-weight: 600;">Flash</text>
  <text x="84" y="132" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--font); font-size: 10px;">meshcore.io/flasher</text>

  <!-- Arrow 1→2 -->
  <line x1="160" y1="80" x2="185" y2="80" style="stroke: var(--border-hover); stroke-width: 1.5;" marker-end="url(#sf-arrow)" />

  <!-- Step 2: Configure -->
  <rect x="187" y="20" width="148" height="120" rx="12" style="fill: var(--surface-1); stroke: var(--border-subtle);" stroke-width="1.25" />
  <text x="261" y="44" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--mono); font-size: 10px; letter-spacing: 0.06em;">02</text>
  <!-- wrench icon -->
  <path d="M248 58 Q253 53 258 58 L268 68 Q263 73 258 68 Z" fill="none" style="stroke: var(--text-muted);" stroke-width="1.5" stroke-linejoin="round" />
  <line x1="268" y1="68" x2="278" y2="78" style="stroke: var(--text-muted);" stroke-width="1.5" stroke-linecap="round" />
  <text x="261" y="116" text-anchor="middle" style="fill: var(--text); font-family: var(--font); font-size: 12px; font-weight: 600;">Configure</text>
  <text x="261" y="132" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--font); font-size: 10px;">name + radio settings</text>

  <!-- Arrow 2→3 -->
  <line x1="337" y1="80" x2="362" y2="80" style="stroke: var(--border-hover); stroke-width: 1.5;" marker-end="url(#sf-arrow)" />

  <!-- Step 3: Power On -->
  <rect x="364" y="20" width="148" height="120" rx="12" style="fill: var(--surface-1); stroke: var(--border-subtle);" stroke-width="1.25" />
  <text x="438" y="44" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--mono); font-size: 10px; letter-spacing: 0.06em;">03</text>
  <!-- power icon -->
  <circle cx="438" cy="70" r="14" fill="none" style="stroke: var(--text-muted);" stroke-width="1.5" />
  <line x1="438" y1="56" x2="438" y2="63" style="stroke: var(--text-muted);" stroke-width="2" stroke-linecap="round" />
  <path d="M428 62 Q424 80 438 84 Q452 80 448 62" fill="none" style="stroke: var(--text-muted);" stroke-width="1.5" stroke-linecap="round" />
  <text x="438" y="116" text-anchor="middle" style="fill: var(--text); font-family: var(--font); font-size: 12px; font-weight: 600;">Power On</text>
  <text x="438" y="132" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--font); font-size: 10px;">both nodes</text>

  <!-- Arrow 3→4 -->
  <line x1="514" y1="80" x2="539" y2="80" style="stroke: var(--border-hover); stroke-width: 1.5;" marker-end="url(#sf-arrow)" />

  <!-- Step 4: Confirm Link -->
  <rect x="541" y="20" width="168" height="120" rx="12" style="fill: var(--surface-1); stroke: var(--border-subtle);" stroke-width="1.25" />
  <text x="625" y="44" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--mono); font-size: 10px; letter-spacing: 0.06em;">04</text>
  <!-- SNR reading icon -->
  <rect x="597" y="52" width="56" height="30" rx="5" style="fill: none; stroke: var(--text-muted);" stroke-width="1.5" />
  <text x="625" y="72" text-anchor="middle" style="fill: var(--accent-light); font-family: var(--mono); font-size: 13px; font-weight: 700;">+9 dB</text>
  <text x="625" y="116" text-anchor="middle" style="fill: var(--text); font-family: var(--font); font-size: 12px; font-weight: 600;">Confirm Link</text>
  <text x="625" y="132" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--font); font-size: 10px;">watch for SNR in app</text>
</svg>
