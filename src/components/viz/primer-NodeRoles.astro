---
/**
 * primer-NodeRoles — the three MeshCore firmware roles:
 *   Companion · Repeater · Room Server
 * Theme-aware via CSS custom properties. Pure SVG, no client JS.
 */
---

<svg viewBox="0 0 720 200" role="img" aria-label="Three MeshCore firmware roles arranged side by side. Left: Companion — the personal radio paired with the app via BLE, does not relay. Center: Repeater — a fixed node that relays packets to extend range. Right: Room Server — stores group messages for offline members." style="width:100%;height:auto;">
  <defs>
    <marker id="pr-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
      <path d="M0 0L10 5L0 10z" style="fill: var(--border-hover);" />
    </marker>
  </defs>

  <!-- ── Companion (left) ── -->
  <rect x="20" y="30" width="180" height="140" rx="16" style="fill: var(--surface-1); stroke: var(--text-accent);" stroke-width="1.5" />
  <rect x="88" y="52" width="24" height="40" rx="4" style="fill: none; stroke: var(--text-accent);" stroke-width="2" />
  <circle cx="100" cy="87" r="2.5" style="fill: var(--text-accent);" />
  <path d="M116 65 Q121 72 116 79" fill="none" style="stroke: var(--text-accent); opacity: 0.7;" stroke-width="1.5" stroke-linecap="round" />
  <path d="M120 62 Q127 72 120 82" fill="none" style="stroke: var(--text-accent); opacity: 0.35;" stroke-width="1.2" stroke-linecap="round" />
  <text x="110" y="112" text-anchor="middle" style="fill: var(--text); font-family: var(--font); font-size: 13px; font-weight: 700;">Companion</text>
  <text x="110" y="130" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">Your personal radio.</text>
  <text x="110" y="146" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">Pairs via BLE to the app.</text>
  <text x="110" y="162" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">Does not relay.</text>

  <!-- Arrows between boxes -->
  <line x1="202" y1="100" x2="268" y2="100" style="stroke: var(--border-hover); stroke-width: 1.5;" marker-end="url(#pr-arrow)" />
  <line x1="268" y1="100" x2="202" y2="100" style="stroke: var(--border-hover); stroke-width: 1.5;" marker-end="url(#pr-arrow)" />

  <!-- ── Repeater (center) ── -->
  <rect x="270" y="30" width="180" height="140" rx="16" style="fill: var(--surface-1); stroke: var(--border-subtle);" stroke-width="1.25" />
  <line x1="360" y1="90" x2="360" y2="55" style="stroke: var(--text-muted);" stroke-width="2" stroke-linecap="round" />
  <path d="M348 64 Q355 57 362 64" fill="none" style="stroke: var(--text-muted); opacity: 0.7;" stroke-width="1.5" stroke-linecap="round" />
  <path d="M343 68 Q355 57 367 68" fill="none" style="stroke: var(--text-muted); opacity: 0.4;" stroke-width="1.3" stroke-linecap="round" />
  <rect x="350" y="90" width="20" height="12" rx="3" style="fill: none; stroke: var(--text-muted);" stroke-width="1.5" />
  <text x="360" y="112" text-anchor="middle" style="fill: var(--text); font-family: var(--font); font-size: 13px; font-weight: 700;">Repeater</text>
  <text x="360" y="130" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">Fixed. Extends range</text>
  <text x="360" y="146" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">by relaying packets.</text>
  <text x="360" y="162" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">Place high.</text>

  <line x1="452" y1="100" x2="518" y2="100" style="stroke: var(--border-hover); stroke-width: 1.5;" marker-end="url(#pr-arrow)" />
  <line x1="518" y1="100" x2="452" y2="100" style="stroke: var(--border-hover); stroke-width: 1.5;" marker-end="url(#pr-arrow)" />

  <!-- ── Room Server (right) ── -->
  <rect x="520" y="30" width="180" height="140" rx="16" style="fill: var(--surface-1); stroke: var(--border-subtle);" stroke-width="1.25" />
  <rect x="580" y="50" width="40" height="11" rx="3" style="fill: none; stroke: var(--text-muted);" stroke-width="1.5" />
  <circle cx="590" cy="56" r="2" style="fill: var(--text-muted);" />
  <rect x="580" y="66" width="40" height="11" rx="3" style="fill: none; stroke: var(--text-muted);" stroke-width="1.5" />
  <circle cx="590" cy="72" r="2" style="fill: var(--text-muted);" />
  <rect x="580" y="82" width="40" height="11" rx="3" style="fill: none; stroke: var(--text-muted);" stroke-width="1.5" />
  <circle cx="590" cy="88" r="2" style="fill: var(--text-muted);" />
  <text x="610" y="112" text-anchor="middle" style="fill: var(--text); font-family: var(--font); font-size: 13px; font-weight: 700;">Room Server</text>
  <text x="610" y="130" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">Stores group messages.</text>
  <text x="610" y="146" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">Members receive them</text>
  <text x="610" y="162" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--font); font-size: 11px;">when back in range.</text>
</svg>
