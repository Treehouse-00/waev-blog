---
/**
 * byob-Credentials — the credential control model.
 * Left side: YOUR BROKER shows who you've issued credentials to.
 * Right side: shows the three actions the operator can take
 *   (rotate, add subscriber, revoke) — all without asking Waev's permission.
 * Theme-aware via CSS custom properties.
 */
const actions = [
  { label: "add read-only subscriber",  note: "give Waev access when ready",  color: "var(--accent-light)" },
  { label: "rotate credentials",        note: "new password, Waev reconnects", color: "var(--text-muted)"   },
  { label: "revoke credentials",        note: "Waev access ends; data intact",  color: "var(--sys-orangeyellow-600)" },
];
---

<svg viewBox="0 0 720 220" role="img" aria-label="Credential control model. The operator's MQTT broker shows one read-only subscriber (Waev). The operator can add subscribers, rotate credentials, or revoke access entirely — all without Waev's involvement. Revoking Waev's credentials ends its access but leaves the operator's data untouched." style="width:100%;height:auto;">
  <defs>
    <marker id="byob-cr-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M0 0L10 5L0 10z" style="fill: var(--border-hover);" />
    </marker>
  </defs>

  <!-- Left: Your Broker credential panel -->
  <rect x="20" y="20" width="300" height="180" rx="14"
    style="fill: var(--surface-1); stroke: var(--border-accent);"
    stroke-width="1.5" />
  <text x="170" y="46" text-anchor="middle" class="viz-label"
    style="fill: var(--text-accent); letter-spacing: 0.06em;">YOUR BROKER — CREDENTIALS</text>
  <line x1="40" y1="56" x2="300" y2="56" style="stroke: var(--border-subtle);" stroke-width="0.8" />

  <!-- Credential rows -->
  <!-- Admin account (you) -->
  <text x="50" y="78" class="viz-label">admin user</text>
  <text x="190" y="78" class="viz-label" style="fill: var(--accent-light);">you (full access)</text>
  <rect x="270" y="68" width="36" height="16" rx="4"
    style="fill: var(--accent-subtle); stroke: var(--border-accent);"
    stroke-width="0.8" />
  <text x="288" y="80" text-anchor="middle" class="viz-label" style="fill: var(--accent-light);">owner</text>

  <line x1="40" y1="92" x2="300" y2="92" style="stroke: var(--border-subtle);" stroke-width="0.5" />

  <!-- Waev read-only account -->
  <text x="50" y="112" class="viz-label">waev-sub</text>
  <text x="190" y="112" class="viz-label">read-only</text>
  <rect x="268" y="102" width="40" height="16" rx="4"
    style="fill: var(--surface-1); stroke: var(--border-subtle);"
    stroke-width="0.8" />
  <text x="288" y="114" text-anchor="middle" class="viz-label">sub</text>

  <line x1="40" y1="126" x2="300" y2="126" style="stroke: var(--border-subtle);" stroke-width="0.5" />

  <!-- Future subscriber slot -->
  <text x="50" y="146" class="viz-label" style="opacity: 0.4;">+ add subscriber…</text>

  <!-- Border bottom / footer -->
  <line x1="40" y1="160" x2="300" y2="160" style="stroke: var(--border-subtle);" stroke-width="0.8" />
  <text x="170" y="178" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--mono); font-size: 11px;">credentials issued by you</text>
  <text x="170" y="192" text-anchor="middle" class="viz-label">no request to Waev required</text>

  <!-- Divider -->
  <line x1="338" y1="20" x2="338" y2="200" style="stroke: var(--border-subtle);" stroke-width="1" />

  <!-- Right: Actions panel -->
  <text x="530" y="38" text-anchor="middle" class="viz-label"
    style="fill: var(--text-accent); letter-spacing: 0.06em;">OPERATOR CONTROLS</text>

  {actions.map((a, i) => (
    <g transform={`translate(364, ${58 + i * 54})`}>
      <rect x="0" y="0" width="330" height="38" rx="8"
        style={`fill: var(--surface-1); stroke: ${a.color}; opacity: 0.9;`}
        stroke-width="1" />
      <text x="16" y="15" style={`fill: ${a.color}; font-family: var(--mono); font-size: 11px; font-weight: 600;`}>
        {a.label}
      </text>
      <text x="16" y="30" class="viz-label">{a.note}</text>
    </g>
  ))}
</svg>
