---
/**
 * buildout-LayoutMap — plan-view top-down layout of a small off-grid mesh
 * buildout across a homestead: main house, workshop, barn, and a ridge
 * repeater. Shows coverage circles and MQTT uplink from the observer node.
 * Theme-aware via CSS custom properties.
 */
---

<svg viewBox="0 0 720 280" role="img" aria-label="Plan-view of an off-grid homestead mesh buildout. Four nodes cover the main house, workshop, barn, and a ridge repeater. Coverage circles overlap to show linked zones. The observer node at the main house sends data to a self-hosted MQTT broker." style="width:100%;height:auto;">
  <defs>
    <marker id="bl-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M0 0L10 5L0 10z" style="fill: var(--accent-light);" />
    </marker>
    <marker id="bl-arrow-dim" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
      <path d="M0 0L10 5L0 10z" style="fill: var(--border-hover);" />
    </marker>
  </defs>

  <!-- Coverage circles (drawn first, behind nodes) -->
  <circle cx="170" cy="180" r="90" style="fill: var(--accent); opacity: 0.06;" />
  <circle cx="170" cy="180" r="90" fill="none" style="stroke: var(--accent-light); opacity: 0.18;" stroke-width="1" stroke-dasharray="5 4" />
  <circle cx="310" cy="120" r="80" style="fill: var(--text-accent); opacity: 0.05;" />
  <circle cx="310" cy="120" r="80" fill="none" style="stroke: var(--text-accent); opacity: 0.15;" stroke-width="1" stroke-dasharray="5 4" />
  <circle cx="420" cy="200" r="75" style="fill: var(--border-hover); opacity: 0.07;" />
  <circle cx="420" cy="200" r="75" fill="none" style="stroke: var(--border-hover); opacity: 0.2;" stroke-width="1" stroke-dasharray="5 4" />
  <circle cx="570" cy="80" r="120" style="fill: var(--text-accent); opacity: 0.04;" />
  <circle cx="570" cy="80" r="120" fill="none" style="stroke: var(--text-accent); opacity: 0.12;" stroke-width="1" stroke-dasharray="5 4" />

  <!-- RF edges -->
  <line x1="195" y1="170" x2="290" y2="128" style="stroke: var(--border-hover);" stroke-width="1.5" stroke-dasharray="5 4" marker-end="url(#bl-arrow-dim)" />
  <line x1="330" y1="134" x2="404" y2="192" style="stroke: var(--border-hover);" stroke-width="1.5" stroke-dasharray="5 4" marker-end="url(#bl-arrow-dim)" />
  <line x1="322" y1="106" x2="548" y2="88" style="stroke: var(--border-hover);" stroke-width="1.5" stroke-dasharray="5 4" marker-end="url(#bl-arrow-dim)" />

  <!-- MQTT uplink -->
  <path d="M162 160 C 100 130 80 60 100 40" fill="none" style="stroke: var(--accent-light);" stroke-width="1.75" marker-end="url(#bl-arrow)" />
  <text x="72" y="30" class="viz-label" style="fill: var(--accent-light); font-size: 10px;">MQTT uplink</text>
  <text x="72" y="44" class="viz-label" style="fill: var(--text-muted); font-size: 10px;">your broker</text>

  <!-- Main house — observer -->
  <circle cx="170" cy="180" r="16" style="fill: var(--accent); opacity:0.9;" />
  <text x="170" y="184" text-anchor="middle" class="viz-label" style="fill: var(--surface-1); font-size:8px; font-weight:600;">OBS</text>
  <rect x="138" y="202" width="64" height="16" rx="8" style="fill: var(--accent-subtle); stroke: var(--border-accent);" stroke-width="1" />
  <text x="170" y="214" text-anchor="middle" style="fill: var(--accent-light); font-family: var(--mono); font-size: 10px;">enrolled</text>
  <text x="170" y="236" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">main house</text>

  <!-- Workshop — repeater -->
  <rect x="297" y="108" width="26" height="26" rx="5" style="fill: var(--text-accent); opacity:0.85;" />
  <text x="310" y="124" text-anchor="middle" class="viz-label" style="fill: var(--surface-1); font-size:8px; font-weight:600;">RPT</text>
  <text x="310" y="152" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">workshop</text>

  <!-- Barn — node -->
  <circle cx="420" cy="200" r="12" style="fill: var(--surface-1); stroke: var(--text-tertiary);" stroke-width="1.5" />
  <circle cx="420" cy="200" r="3" style="fill: var(--text-muted);" />
  <text x="420" y="222" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">barn</text>

  <!-- Ridge repeater -->
  <rect x="556" y="66" width="28" height="28" rx="6" style="fill: var(--accent);" />
  <text x="570" y="83" text-anchor="middle" class="viz-label" style="fill: var(--surface-1); font-size:8px; font-weight:600;">RPT</text>
  <text x="570" y="108" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">ridge</text>
  <text x="600" y="74" class="viz-label" style="fill: var(--text-muted); font-size: 10px; font-style: italic;">high ground</text>

  <!-- Legend -->
  <circle cx="128" cy="264" r="6" style="fill: var(--accent); opacity:0.9;" />
  <text x="140" y="268" class="viz-label" style="font-size:10px; fill: var(--text-muted);">observer</text>
  <rect x="196" y="258" width="12" height="12" rx="3" style="fill: var(--text-accent); opacity:0.85;" />
  <text x="214" y="268" class="viz-label" style="font-size:10px; fill: var(--text-muted);">repeater</text>
  <circle cx="276" cy="264" r="6" style="fill: var(--surface-1); stroke: var(--text-tertiary);" stroke-width="1.5" />
  <text x="288" y="268" class="viz-label" style="font-size:10px; fill: var(--text-muted);">node</text>
  <line x1="336" y1="264" x2="364" y2="264" style="stroke: var(--border-hover);" stroke-width="1.5" stroke-dasharray="5 4" />
  <text x="372" y="268" class="viz-label" style="font-size:10px; fill: var(--text-muted);">RF link</text>
  <line x1="424" y1="264" x2="452" y2="264" style="stroke: var(--accent-light);" stroke-width="1.5" />
  <text x="460" y="268" class="viz-label" style="font-size:10px; fill: var(--text-muted);">MQTT uplink</text>
</svg>
