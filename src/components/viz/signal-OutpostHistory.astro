---
/**
 * signal-OutpostHistory — abstracted Outpost SNR-history panel.
 * Shows a 24-hour sparkline with:
 *   · a shaded "comfortable zone" band (+7 to +13 dB)
 *   · a working-threshold line at +7 dB
 *   · a path that dips below the threshold and recovers (annotated)
 * Theme-aware via CSS custom properties.
 */
---

<svg viewBox="0 0 720 190" role="img" aria-label="Outpost SNR history over 24 hours. SNR is stable around plus 10 dB for most of the period. Between hours 16 and 20 it dips below the plus 7 dB working threshold, bottoming near plus 1 dB before recovering. A comfortable zone band spans plus 7 to plus 13 dB." style="width:100%;height:auto;">

  <!-- ── Panel chrome ── -->
  <rect x="18" y="14" width="684" height="166" rx="14" style="fill: var(--surface-1); stroke: var(--border-subtle);" stroke-width="1" />

  <!-- ── Panel title ── -->
  <text x="38" y="36" class="viz-label" style="fill: var(--text-accent); letter-spacing:0.06em;">OUTPOST · SNR HISTORY · 24 H</text>
  <text x="682" y="36" text-anchor="end" class="viz-label" style="fill: var(--text-muted);">relay-ridge</text>

  <!-- ────────────────────────────────────────────────
       Chart area: x=66–672 (606px), y=48–148 (100px)
       Y: +15 dB → y=48, −5 dB → y=148  (5 px / dB)
       X: 0h → x=66, 24h → x=672  (25.25 px / h)
       ──────────────────────────────────────────────── -->

  <!-- ── Comfortable zone band: +7 dB (y=88) to +13 dB (y=58) ── -->
  <rect x="66" y="58" width="606" height="30" rx="0" style="fill: var(--accent-light);" opacity="0.12" />

  <!-- ── Threshold line at +7 dB (y=88) ── -->
  <line x1="66" y1="88" x2="672" y2="88" style="stroke: var(--accent-light); opacity:0.5;" stroke-width="1" stroke-dasharray="4 4" />
  <text x="60" y="92" text-anchor="end" class="viz-label" style="fill: var(--accent-light);">+7</text>

  <!-- ── Y-axis labels ── -->
  <text x="60" y="58" text-anchor="end" class="viz-label" style="fill: var(--text-muted);">+13</text>
  <text x="60" y="78" text-anchor="end" class="viz-label" style="fill: var(--text-muted);">+10</text>
  <text x="60" y="118" text-anchor="end" class="viz-label" style="fill: var(--text-muted);">+3</text>
  <text x="60" y="148" text-anchor="end" class="viz-label" style="fill: var(--text-muted);">−5</text>

  <!-- ── Y-axis gridlines (subtle) ── -->
  <line x1="66" y1="78"  x2="672" y2="78"  style="stroke: var(--border-subtle); opacity:0.5;" stroke-width="1" />
  <line x1="66" y1="118" x2="672" y2="118" style="stroke: var(--border-subtle); opacity:0.5;" stroke-width="1" />
  <line x1="66" y1="148" x2="672" y2="148" style="stroke: var(--border-subtle); opacity:0.4;" stroke-width="1" />

  <!-- ── SNR sparkline
       y = 48 + (15 − snr) × 5
       x = 66 + h × 25.25

       Keypoints:
         0h:    +10.0 dB → y=78,  x=66
         4h:    +10.8 dB → y=74,  x=167
         8h:    +10.0 dB → y=78,  x=268
         12h:   +10.5 dB → y=75,  x=369
         14h:   +9.0  dB → y=83,  x=420
         16h:   +6.2  dB → y=96,  x=470
         17h:   +3.5  dB → y=108, x=495
         17.5h: +1.2  dB → y=118, x=508
         18.5h: +3.8  dB → y=106, x=533
         20h:   +7.2  dB → y=87,  x=571
         22h:   +9.8  dB → y=78,  x=622
         24h:   +10.5 dB → y=75,  x=672
       ── -->
  <polyline
    points="66,78 167,74 268,78 369,75 420,83 470,96 495,108 508,118 533,106 571,87 622,78 672,75"
    fill="none"
    style="stroke: var(--accent-light);"
    stroke-width="2"
    stroke-linejoin="round"
    stroke-linecap="round"
  />

  <!-- ── Dip highlight + annotation ── -->
  <!-- Red fill under the line when it's below threshold -->
  <polygon
    points="470,96 495,108 508,118 533,106 571,87 571,88 533,88 508,88 495,88 470,88"
    style="fill: var(--sys-red-400);"
    opacity="0.15"
  />
  <!-- Dot at the bottom of the dip -->
  <circle cx="508" cy="118" r="4" style="fill: var(--sys-orangeyellow-600); stroke: var(--surface-1);" stroke-width="1.5" />
  <!-- Annotation leader line + text -->
  <line x1="508" y1="118" x2="508" y2="138" style="stroke: var(--text-tertiary);" stroke-width="1" stroke-dasharray="2 3" />
  <text x="516" y="142" class="viz-label" style="fill: var(--sys-orangeyellow-600);">below +7 dB · ~4 h</text>

  <!-- ── X-axis labels ── -->
  <text x="66"  y="162" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">0h</text>
  <text x="268" y="162" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">8h</text>
  <text x="470" y="162" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">16h</text>
  <text x="672" y="162" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">24h</text>

  <!-- ── Comfortable zone label inside band ── -->
  <text x="674" y="76" text-anchor="start" class="viz-label" style="fill: var(--accent-light); opacity:0.8;">comfortable</text>
  <text x="674" y="90" text-anchor="start" class="viz-label" style="fill: var(--accent-light); opacity:0.8;">zone</text>
</svg>
