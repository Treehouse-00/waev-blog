---
/**
 * TrustedSources — two lanes contrasting evidence vs inference:
 *   Lane A: enrolled observer + authenticated repeater → edge IS drawn.
 *   Lane B: a spoofed/inferred prefix → edge is rejected.
 */
---

<svg viewBox="0 0 720 300" role="img" aria-label="Topology edges are drawn only from verified observers and authenticated repeaters; inferred or spoofed sources are rejected." style="width:100%;height:auto;">
  <defs>
    <marker id="ts-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
      <path d="M0 0L10 5L0 10z" style="fill: var(--accent-light);" />
    </marker>
    <marker id="ts-arrow-dim" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
      <path d="M0 0L10 5L0 10z" style="fill: var(--text-muted);" />
    </marker>
  </defs>

  <!-- ───── Lane A — accepted ───── -->
  <text x="20" y="30" class="viz-label" style="fill: var(--text-accent); letter-spacing:0.06em;">EVIDENCE → DRAWN</text>

  <!-- observer -->
  <g>
    <circle cx="58" cy="66" r="11" style="fill: var(--accent);" />
    <text x="80" y="62" class="viz-label" style="fill: var(--text-muted);">observer</text>
    <text x="80" y="78" style="fill: var(--text-muted); font-family: var(--mono); font-size: 11px;">enrolled · MQTT</text>
  </g>
  <!-- repeater -->
  <g>
    <rect x="48" y="103" width="20" height="20" rx="5" style="fill: var(--text-accent);" />
    <text x="80" y="112" class="viz-label" style="fill: var(--text-muted);">repeater</text>
    <text x="80" y="128" style="fill: var(--text-muted); font-family: var(--mono); font-size: 11px;">authenticated</text>
  </g>

  <!-- solid edges to gate -->
  <path d="M210 66 C 250 66, 250 92, 300 92" fill="none" style="stroke: var(--accent-light);" stroke-width="1.75" />
  <path d="M210 113 C 250 113, 250 92, 300 92" fill="none" style="stroke: var(--accent-light);" stroke-width="1.75" />

  <!-- verify gate (check) -->
  <g transform="translate(318 92)">
    <circle cx="0" cy="0" r="16" style="fill: var(--accent-subtle); stroke: var(--border-accent);" stroke-width="1" />
    <path d="M-7 0 L-2 6 L8 -6" fill="none" style="stroke: var(--accent-light);" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
  </g>

  <line x1="338" y1="92" x2="436" y2="92" style="stroke: var(--accent-light);" stroke-width="1.75" marker-end="url(#ts-arrow)" />

  <!-- result card -->
  <g>
    <rect x="446" y="66" width="254" height="52" rx="14" style="fill: var(--surface-1); stroke: var(--border-accent);" stroke-width="1" />
    <text x="470" y="88" class="viz-label" style="fill: var(--text-muted);">topology edge</text>
    <text x="470" y="106" style="fill: var(--accent-light); font-family: var(--mono); font-size: 14px;">drawn — backed by evidence</text>
  </g>

  <!-- divider -->
  <line x1="20" y1="158" x2="700" y2="158" style="stroke: var(--border-subtle);" stroke-width="1" />

  <!-- ───── Lane B — rejected ───── -->
  <text x="20" y="192" class="viz-label" style="fill: var(--text-muted); letter-spacing:0.06em;">INFERENCE → REJECTED</text>

  <g>
    <circle cx="58" cy="232" r="11" fill="none" style="stroke: var(--text-tertiary);" stroke-width="1.5" stroke-dasharray="3 3" />
    <text x="80" y="228" class="viz-label" style="fill: var(--text-muted);">spoofed prefix</text>
    <text x="80" y="244" style="fill: var(--text-muted); font-family: var(--mono); font-size: 11px;">0x3F · unverified</text>
  </g>

  <line x1="210" y1="232" x2="300" y2="232" style="stroke: var(--text-tertiary);" stroke-width="1.5" stroke-dasharray="4 4" marker-end="url(#ts-arrow-dim)" />

  <!-- reject gate (x) -->
  <g transform="translate(318 232)">
    <circle cx="0" cy="0" r="16" fill="none" style="stroke: var(--text-tertiary);" stroke-width="1.5" />
    <line x1="-6" y1="-6" x2="6" y2="6" style="stroke: var(--text-tertiary);" stroke-width="2.5" stroke-linecap="round" />
    <line x1="6" y1="-6" x2="-6" y2="6" style="stroke: var(--text-tertiary);" stroke-width="2.5" stroke-linecap="round" />
  </g>

  <line x1="338" y1="232" x2="436" y2="232" style="stroke: var(--text-tertiary);" stroke-width="1.5" stroke-dasharray="4 4" marker-end="url(#ts-arrow-dim)" />

  <g>
    <rect x="446" y="206" width="254" height="52" rx="14" style="fill: transparent; stroke: var(--border-hover);" stroke-width="1" stroke-dasharray="5 5" />
    <text x="470" y="228" class="viz-label" style="fill: var(--text-muted);">topology edge</text>
    <text x="470" y="246" style="fill: var(--text-muted); font-family: var(--mono); font-size: 14px;">not drawn — no proof</text>
  </g>
</svg>
