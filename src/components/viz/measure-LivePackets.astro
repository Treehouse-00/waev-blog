---
/**
 * measure-LivePackets — a Live Packets view showing per-observation SNR
 * readings for four nodes, illustrating where SNR surfaces in Waev.
 * Theme-aware via CSS custom properties. Pure SVG, no client JS.
 */
---

<svg viewBox="0 0 720 270" role="img" aria-label="Live Packets panel showing four incoming observations. Each row shows a timestamp, source node name, hop count, and SNR reading. Readings range from plus 11 dB (healthy) down to minus 2 dB (degraded). The third row shows relay-east at 3 hops and plus 4 dB flagged as watchlist." style="width:100%;height:auto;">

  <!-- Panel chrome -->
  <rect x="18" y="16" width="684" height="240" rx="14" style="fill: var(--surface-1); stroke: var(--border-subtle);" stroke-width="1" />

  <!-- Panel title -->
  <text x="38" y="40" class="viz-label" style="fill: var(--text-accent); letter-spacing:0.06em;">LIVE PACKETS</text>
  <text x="680" y="40" text-anchor="end" class="viz-label" style="fill: var(--text-muted);">LIVE</text>
  <circle cx="695" cy="36" r="4" style="fill: var(--accent-light);" />

  <!-- Header -->
  <line x1="18" y1="52" x2="702" y2="52" style="stroke: var(--border-subtle);" stroke-width="1" />
  <text x="38" y="68" class="viz-label" style="fill: var(--text-muted);">TIME</text>
  <text x="160" y="68" class="viz-label" style="fill: var(--text-muted);">NODE</text>
  <text x="380" y="68" class="viz-label" style="fill: var(--text-muted);">HOPS</text>
  <text x="480" y="68" class="viz-label" style="fill: var(--text-muted);">SNR</text>
  <text x="590" y="68" class="viz-label" style="fill: var(--text-muted);">STATUS</text>
  <line x1="18" y1="76" x2="702" y2="76" style="stroke: var(--border-subtle);" stroke-width="1" />

  <!-- Row 1: relay-main, 1 hop, +11 dB, healthy -->
  <text x="38" y="103" style="font-family: var(--mono); font-size: 12px; fill: var(--text-muted);">17:04:12</text>
  <text x="160" y="103" style="font-family: var(--mono); font-size: 13px; fill: var(--text);">relay-main</text>
  <text x="380" y="103" style="font-family: var(--mono); font-size: 12px; fill: var(--text-muted);">1</text>
  <text x="480" y="103" style="font-family: var(--mono); font-size: 14px; font-weight: 700; fill: var(--accent-light);">+11 dB</text>
  <circle cx="598" cy="99" r="5" style="fill: var(--accent-light);" />
  <text x="610" y="103" style="font-family: var(--mono); font-size: 11px; fill: var(--accent-light);">healthy</text>

  <!-- Row 2 alt bg -->
  <rect x="19" y="110" width="682" height="40" style="fill: var(--surface-sunken); opacity: 0.5;" />
  <!-- relay-north, 2 hops, +7 dB, healthy -->
  <text x="38" y="135" style="font-family: var(--mono); font-size: 12px; fill: var(--text-muted);">17:03:58</text>
  <text x="160" y="135" style="font-family: var(--mono); font-size: 13px; fill: var(--text);">relay-north</text>
  <text x="380" y="135" style="font-family: var(--mono); font-size: 12px; fill: var(--text-muted);">2</text>
  <text x="480" y="135" style="font-family: var(--mono); font-size: 14px; font-weight: 700; fill: var(--accent-light);">+7 dB</text>
  <circle cx="598" cy="131" r="5" style="fill: var(--accent-light);" />
  <text x="610" y="135" style="font-family: var(--mono); font-size: 11px; fill: var(--accent-light);">healthy</text>

  <!-- Row 3: relay-east, 3 hops, +4 dB, watchlist -->
  <line x1="18" y1="150" x2="702" y2="150" style="stroke: var(--border-subtle); opacity: 0.5;" stroke-width="1" />
  <text x="38" y="175" style="font-family: var(--mono); font-size: 12px; fill: var(--text-muted);">17:03:41</text>
  <text x="160" y="175" style="font-family: var(--mono); font-size: 13px; fill: var(--text);">relay-east</text>
  <text x="380" y="175" style="font-family: var(--mono); font-size: 12px; fill: var(--text-muted);">3</text>
  <text x="480" y="175" style="font-family: var(--mono); font-size: 14px; font-weight: 700; fill: var(--sys-orangeyellow-600);">+4 dB</text>
  <circle cx="598" cy="171" r="5" style="fill: var(--sys-orangeyellow-600);" />
  <text x="610" y="175" style="font-family: var(--mono); font-size: 11px; fill: var(--sys-orangeyellow-600);">watchlist ⚠</text>

  <!-- Row 4 alt bg -->
  <rect x="19" y="182" width="682" height="40" style="fill: var(--surface-sunken); opacity: 0.5;" />
  <!-- ridge-relay, 4 hops, -2 dB, degraded -->
  <text x="38" y="207" style="font-family: var(--mono); font-size: 12px; fill: var(--text-muted);">17:02:09</text>
  <text x="160" y="207" style="font-family: var(--mono); font-size: 13px; fill: var(--text);">ridge-relay</text>
  <text x="380" y="207" style="font-family: var(--mono); font-size: 12px; fill: var(--text-muted);">4</text>
  <text x="480" y="207" style="font-family: var(--mono); font-size: 14px; font-weight: 700; fill: var(--sys-red-400);">–2 dB</text>
  <circle cx="598" cy="203" r="5" style="fill: var(--sys-red-400);" />
  <text x="610" y="207" style="font-family: var(--mono); font-size: 11px; fill: var(--sys-red-400);">degraded</text>

  <!-- Bottom note -->
  <line x1="18" y1="222" x2="702" y2="222" style="stroke: var(--border-subtle);" stroke-width="1" />
  <text x="38" y="244" class="viz-label" style="fill: var(--text-muted);">SNR and hop count appear on every packet — the two numbers that describe link quality</text>
</svg>
