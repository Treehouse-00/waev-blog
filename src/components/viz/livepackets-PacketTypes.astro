---
/**
 * livepackets-PacketTypes — Live Packets stream showing five packet types
 * common in a MeshCore mesh: ADVERT, MSG, GRP_TXT, PATH, and ACK.
 * Each row shows the type badge, source node, SNR, and hop count so readers
 * can recognise each type in their own stream.
 * Theme-aware via CSS custom properties. No client JS. Pure SVG.
 */
---

<svg viewBox="0 0 720 330" role="img" aria-label="Live Packets panel showing five packet types in sequence. Row 1: ADVERT from ridge-relay at plus 11 dB, 2 hops, 11:47:03. Row 2: MSG from w6abc-home at plus 7 dB, 1 hop, 11:47:08. Row 3: GRP_TXT from kd9zzz-ops at plus 6 dB, 2 hops, 11:47:15. Row 4: PATH from ridge-relay at plus 11 dB, 2 hops, 11:47:22. Row 5: ACK from w6abc-home at plus 7 dB, 1 hop, 11:47:22. A legend at the bottom describes what each type means." style="width:100%;height:auto;">

  <!-- Panel chrome -->
  <rect x="18" y="16" width="684" height="286" rx="14"
    style="fill: var(--surface-1); stroke: var(--border-subtle);" stroke-width="1" />

  <!-- Panel title -->
  <text x="38" y="40" class="viz-label"
    style="fill: var(--text-accent); letter-spacing:0.06em;">LIVE PACKETS</text>
  <text x="680" y="40" text-anchor="end" class="viz-label"
    style="fill: var(--text-muted);">LIVE</text>
  <circle cx="695" cy="36" r="4" style="fill: var(--accent-light);" />

  <!-- Header divider -->
  <line x1="18" y1="52" x2="702" y2="52"
    style="stroke: var(--border-subtle);" stroke-width="1" />

  <!-- Column headers -->
  <text x="38"  y="68" class="viz-label" style="fill: var(--text-muted);">TIME</text>
  <text x="134" y="68" class="viz-label" style="fill: var(--text-muted);">TYPE</text>
  <text x="240" y="68" class="viz-label" style="fill: var(--text-muted);">NODE</text>
  <text x="462" y="68" class="viz-label" style="fill: var(--text-muted);">SNR</text>
  <text x="556" y="68" class="viz-label" style="fill: var(--text-muted);">HOPS</text>

  <!-- Column header divider -->
  <line x1="18" y1="76" x2="702" y2="76"
    style="stroke: var(--border-subtle);" stroke-width="1" />

  <!-- ── Row 1: ADVERT ── -->
  <text x="38" y="100"
    style="font-family: var(--mono); font-size: 12px; fill: var(--text-muted);">11:47:03</text>
  <rect x="128" y="86" width="70" height="20" rx="5"
    style="fill: var(--accent-subtle); stroke: var(--border-accent);" stroke-width="1" />
  <text x="163" y="100" text-anchor="middle" class="viz-label"
    style="fill: var(--text-accent);">ADVERT</text>
  <text x="240" y="100"
    style="font-family: var(--mono); font-size: 13px; fill: var(--text);">ridge-relay</text>
  <text x="462" y="100"
    style="font-family: var(--mono); font-size: 14px; font-weight: 700; fill: var(--accent-light);">+11 dB</text>
  <text x="556" y="100"
    style="font-family: var(--mono); font-size: 12px; fill: var(--text-muted);">2h</text>

  <!-- ── Row 2 (alt bg): MSG ── -->
  <rect x="19" y="108" width="682" height="40" style="fill: var(--surface-sunken); opacity: 0.6;" />
  <text x="38" y="132"
    style="font-family: var(--mono); font-size: 12px; fill: var(--text-muted);">11:47:08</text>
  <rect x="128" y="118" width="46" height="20" rx="5"
    style="fill: var(--accent-subtle); stroke: var(--border-accent);" stroke-width="1" />
  <text x="151" y="132" text-anchor="middle" class="viz-label"
    style="fill: var(--accent-light);">MSG</text>
  <text x="240" y="132"
    style="font-family: var(--mono); font-size: 13px; fill: var(--text);">w6abc-home</text>
  <text x="462" y="132"
    style="font-family: var(--mono); font-size: 14px; font-weight: 700; fill: var(--accent-light);">+7 dB</text>
  <text x="556" y="132"
    style="font-family: var(--mono); font-size: 12px; fill: var(--text-muted);">1h</text>

  <!-- ── Row 3: GRP_TXT ── -->
  <text x="38" y="164"
    style="font-family: var(--mono); font-size: 12px; fill: var(--text-muted);">11:47:15</text>
  <rect x="128" y="150" width="72" height="20" rx="5"
    style="fill: var(--accent-subtle); stroke: var(--border-accent);" stroke-width="1" />
  <text x="164" y="164" text-anchor="middle" class="viz-label"
    style="fill: var(--text-accent);">GRP_TXT</text>
  <text x="240" y="164"
    style="font-family: var(--mono); font-size: 13px; fill: var(--text);">kd9zzz-ops</text>
  <text x="462" y="164"
    style="font-family: var(--mono); font-size: 14px; font-weight: 700; fill: var(--accent-light);">+6 dB</text>
  <text x="556" y="164"
    style="font-family: var(--mono); font-size: 12px; fill: var(--text-muted);">2h</text>

  <!-- ── Row 4 (alt bg): PATH ── -->
  <rect x="19" y="172" width="682" height="40" style="fill: var(--surface-sunken); opacity: 0.6;" />
  <text x="38" y="196"
    style="font-family: var(--mono); font-size: 12px; fill: var(--text-muted);">11:47:22</text>
  <rect x="128" y="182" width="50" height="20" rx="5"
    style="fill: var(--surface-1); stroke: var(--border-subtle);" stroke-width="1" />
  <text x="153" y="196" text-anchor="middle" class="viz-label"
    style="fill: var(--text-muted);">PATH</text>
  <text x="240" y="196"
    style="font-family: var(--mono); font-size: 13px; fill: var(--text);">ridge-relay</text>
  <text x="462" y="196"
    style="font-family: var(--mono); font-size: 14px; font-weight: 700; fill: var(--accent-light);">+11 dB</text>
  <text x="556" y="196"
    style="font-family: var(--mono); font-size: 12px; fill: var(--text-muted);">2h</text>

  <!-- ── Row 5: ACK ── -->
  <text x="38" y="228"
    style="font-family: var(--mono); font-size: 12px; fill: var(--text-muted);">11:47:22</text>
  <rect x="128" y="214" width="44" height="20" rx="5"
    style="fill: var(--surface-1); stroke: var(--border-subtle);" stroke-width="1" />
  <text x="150" y="228" text-anchor="middle" class="viz-label"
    style="fill: var(--text-muted);">ACK</text>
  <text x="240" y="228"
    style="font-family: var(--mono); font-size: 13px; fill: var(--text);">w6abc-home</text>
  <text x="462" y="228"
    style="font-family: var(--mono); font-size: 14px; font-weight: 700; fill: var(--accent-light);">+7 dB</text>
  <text x="556" y="228"
    style="font-family: var(--mono); font-size: 12px; fill: var(--text-muted);">1h</text>

  <!-- Stream continues -->
  <circle cx="360" cy="248" r="2.5" style="fill: var(--text-muted); opacity: 0.4;" />
  <circle cx="376" cy="248" r="2.5" style="fill: var(--text-muted); opacity: 0.4;" />
  <circle cx="392" cy="248" r="2.5" style="fill: var(--text-muted); opacity: 0.4;" />

  <!-- Divider before legend -->
  <line x1="18" y1="260" x2="702" y2="260"
    style="stroke: var(--border-subtle);" stroke-width="1" />

  <!-- Legend row 1 -->
  <text x="38" y="278" class="viz-label" style="fill: var(--text-muted);">
    ADVERT node presence  ·  MSG direct message  ·  GRP_TXT channel message
  </text>
  <!-- Legend row 2 -->
  <text x="38" y="294" class="viz-label" style="fill: var(--text-muted);">
    PATH route returned after delivery  ·  ACK delivery confirmed
  </text>

</svg>
