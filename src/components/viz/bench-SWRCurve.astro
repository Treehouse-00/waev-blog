---
/**
 * bench-SWRCurve — SWR vs frequency plot for a 915 MHz LoRa antenna.
 * Shows a resonant dip centered at 915 MHz with annotated SWR zones
 * (excellent, good, marginal, poor). Includes a marker at the 915 MHz
 * target frequency. Theme-aware via CSS custom properties. No client JS.
 */
---

<svg viewBox="0 0 720 300" role="img" aria-label="SWR versus frequency plot for a 915 MHz LoRa antenna. The horizontal axis spans 850 to 950 MHz. The vertical axis shows SWR from 1 to 4. The curve shows a resonant dip reaching SWR 1.3 at 915 MHz. Four horizontal zones are marked: excellent (SWR 1.0 to 1.5), good (1.5 to 2.0), marginal (2.0 to 3.0), and poor (above 3.0). A vertical dashed line marks 915 MHz, and a callout reads SWR 1.3 at 915 MHz." style="width:100%;height:auto;">
  <defs>
    <!-- Gradient for the SWR curve fill -->
    <linearGradient id="bsc-curve-fill" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" style="stop-color: var(--sys-red-400); stop-opacity: 0.15;" />
      <stop offset="100%" style="stop-color: var(--sys-red-400); stop-opacity: 0;" />
    </linearGradient>
  </defs>

  <!-- ── Kicker ── -->
  <text x="60" y="22" class="viz-label" style="fill: var(--text-accent); letter-spacing:0.06em;">SWR PLOT — 915 MHz LORA ANTENNA (NANOVNA SWEEP 850–950 MHz)</text>

  <!-- ── Axes ── -->
  <!-- Y-axis -->
  <line x1="60" y1="40" x2="60" y2="240" style="stroke: var(--border-subtle);" stroke-width="1.5" />
  <!-- X-axis -->
  <line x1="60" y1="240" x2="680" y2="240" style="stroke: var(--border-subtle);" stroke-width="1.5" />

  <!-- ── Y-axis ticks and labels (SWR) ── -->
  <!-- SWR = 1.0 (y=240 - scale: each SWR unit = 50px, so y = 240 - (swr-1)*66.7) -->
  <!-- y scale: SWR 1.0 → y=240, SWR 2.0 → y=173, SWR 3.0 → y=107, SWR 4.0 → y=40 -->
  <line x1="55" y1="240" x2="60" y2="240" style="stroke: var(--border-subtle);" stroke-width="1" />
  <text x="50" y="244" text-anchor="end" class="viz-label" style="font-size:9px; fill: var(--text-muted);">1.0</text>
  <line x1="55" y1="173" x2="60" y2="173" style="stroke: var(--border-subtle);" stroke-width="1" />
  <text x="50" y="177" text-anchor="end" class="viz-label" style="font-size:9px; fill: var(--text-muted);">2.0</text>
  <line x1="55" y1="107" x2="60" y2="107" style="stroke: var(--border-subtle);" stroke-width="1" />
  <text x="50" y="111" text-anchor="end" class="viz-label" style="font-size:9px; fill: var(--text-muted);">3.0</text>
  <line x1="55" y1="40" x2="60" y2="40" style="stroke: var(--border-subtle);" stroke-width="1" />
  <text x="50" y="44" text-anchor="end" class="viz-label" style="font-size:9px; fill: var(--text-muted);">4.0</text>
  <text x="20" y="145" text-anchor="middle" class="viz-label" style="font-size:10px; fill: var(--text-muted);" transform="rotate(-90,20,145)">SWR</text>

  <!-- ── X-axis ticks and labels (MHz) ── -->
  <!-- x scale: 850 MHz → x=60, 950 MHz → x=680. 10 MHz per step = 62 px -->
  <line x1="60"  y1="240" x2="60"  y2="245" style="stroke: var(--border-subtle);" stroke-width="1" />
  <text x="60"   y="256" text-anchor="middle" class="viz-label" style="font-size:9px; fill: var(--text-muted);">850</text>
  <line x1="184" y1="240" x2="184" y2="245" style="stroke: var(--border-subtle);" stroke-width="1" />
  <text x="184"  y="256" text-anchor="middle" class="viz-label" style="font-size:9px; fill: var(--text-muted);">870</text>
  <line x1="308" y1="240" x2="308" y2="245" style="stroke: var(--border-subtle);" stroke-width="1" />
  <text x="308"  y="256" text-anchor="middle" class="viz-label" style="font-size:9px; fill: var(--text-muted);">890</text>
  <line x1="432" y1="240" x2="432" y2="245" style="stroke: var(--border-hover);" stroke-width="1.5" />
  <text x="432"  y="256" text-anchor="middle" class="viz-label" style="font-size:10px; font-weight:600; fill: var(--text-accent);">915</text>
  <line x1="556" y1="240" x2="556" y2="245" style="stroke: var(--border-subtle);" stroke-width="1" />
  <text x="556"  y="256" text-anchor="middle" class="viz-label" style="font-size:9px; fill: var(--text-muted);">940</text>
  <line x1="680" y1="240" x2="680" y2="245" style="stroke: var(--border-subtle);" stroke-width="1" />
  <text x="680"  y="256" text-anchor="middle" class="viz-label" style="font-size:9px; fill: var(--text-muted);">950</text>
  <text x="370" y="272" text-anchor="middle" class="viz-label" style="font-size:10px; fill: var(--text-muted);">MHz</text>

  <!-- ── Zone shading ── -->
  <!-- Excellent: SWR 1.0–1.5 → y 207–240 -->
  <rect x="60" y="207" width="620" height="33" style="fill: var(--accent-light);" opacity="0.08" />
  <!-- Good: SWR 1.5–2.0 → y 173–207 -->
  <rect x="60" y="173" width="620" height="34" style="fill: var(--accent-light);" opacity="0.05" />
  <!-- Marginal: SWR 2.0–3.0 → y 107–173 -->
  <rect x="60" y="107" width="620" height="66" style="fill: var(--sys-orangeyellow-600);" opacity="0.05" />
  <!-- Poor: SWR >3.0 → y 40–107 -->
  <rect x="60" y="40" width="620" height="67" style="fill: var(--sys-red-400);" opacity="0.05" />

  <!-- Zone labels (right side) -->
  <text x="690" y="230" class="viz-label" style="fill: var(--accent-light); font-size:9px;">EXCELLENT</text>
  <text x="690" y="196" class="viz-label" style="fill: var(--accent-light); font-size:9px; opacity:0.7;">GOOD</text>
  <text x="690" y="146" class="viz-label" style="fill: var(--sys-orangeyellow-600); font-size:9px;">MARGINAL</text>
  <text x="690" y="72"  class="viz-label" style="fill: var(--sys-red-400); font-size:9px;">POOR</text>

  <!-- Zone boundary dashed lines -->
  <line x1="60" y1="207" x2="680" y2="207" style="stroke: var(--accent-light);" stroke-width="0.75" stroke-dasharray="4 3" opacity="0.5" />
  <line x1="60" y1="173" x2="680" y2="173" style="stroke: var(--accent-light);" stroke-width="0.75" stroke-dasharray="4 3" opacity="0.3" />
  <line x1="60" y1="107" x2="680" y2="107" style="stroke: var(--sys-orangeyellow-600);" stroke-width="0.75" stroke-dasharray="4 3" opacity="0.4" />

  <!-- ── SWR Curve ── -->
  <!-- Points: x = 60 + (MHz-850)*6.2, y = 240 - (SWR-1)*66.7 -->
  <!-- Curve dips to ~1.3 at 915 MHz, rises to ~2.8 at edges -->
  <!-- Filled area under curve -->
  <path d="M60,100 C120,100 150,95 200,100 C240,104 280,118 308,126 C330,130 365,140 390,160 C405,172 415,190 432,220 C449,190 459,172 474,160 C501,140 536,130 558,126 C586,118 626,104 666,100 C680,98 680,98 680,240 L60,240 Z" style="fill: url(#bsc-curve-fill);" />
  <!-- Curve line -->
  <path d="M60,100 C120,100 150,95 200,100 C240,104 280,118 308,126 C330,130 365,140 390,160 C405,172 415,190 432,220 C449,190 459,172 474,160 C501,140 536,130 558,126 C586,118 626,104 666,100 C680,98 680,98 680,96" style="fill:none; stroke: var(--sys-red-400); stroke-width:2;" />

  <!-- ── 915 MHz vertical marker ── -->
  <line x1="432" y1="40" x2="432" y2="240" style="stroke: var(--border-hover);" stroke-width="1.5" stroke-dasharray="5 3" />

  <!-- ── Callout at the dip ── -->
  <circle cx="432" cy="220" r="5" style="fill: var(--accent-light); stroke: var(--surface-1);" stroke-width="1.5" />
  <rect x="440" y="190" width="100" height="30" rx="6" style="fill: var(--surface-1); stroke: var(--border-subtle);" stroke-width="1" />
  <text x="490" y="204" text-anchor="middle" class="viz-label" style="fill: var(--text-accent);">SWR 1.3</text>
  <text x="490" y="217" text-anchor="middle" class="viz-label" style="fill: var(--text-muted); font-size:9px;">at 915 MHz ✓</text>
  <line x1="440" y1="210" x2="437" y2="220" style="stroke: var(--border-subtle);" stroke-width="1" />
</svg>
