---
/**
 * mesh-AdvertTimeline — two-row timeline comparing normal advert cadence
 * vs a chatty node flooding adverts at short intervals.
 * Theme-aware via CSS custom properties. Pure SVG, no client JS.
 */
---

<svg viewBox="0 0 720 200" role="img" aria-label="Two-row timeline comparing advert cadence. Top row: normal repeater, adverts spaced roughly every 47 hours — only one advert visible in the 4-hour window. Bottom row: chatty node, adverts every 2 to 5 minutes — a dense cluster of ticks filling the same 4-hour window." style="width:100%;height:auto;">

  <!-- Axis labels -->
  <text x="20" y="28" style="fill: var(--text-muted); font-family: var(--mono); font-size: 10px; letter-spacing: 0.06em;">NODE</text>
  <text x="300" y="28" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--mono); font-size: 10px;">← 4-hour window →</text>
  <text x="700" y="28" text-anchor="end" style="fill: var(--text-muted); font-family: var(--mono); font-size: 10px;">FLOOD ADVERT RATE</text>

  <!-- Time axis -->
  <line x1="200" y1="36" x2="710" y2="36" style="stroke: var(--border-subtle);" stroke-width="1" />
  <text x="200" y="50" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--mono); font-size: 9px;">T+0h</text>
  <text x="327" y="50" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--mono); font-size: 9px;">T+1h</text>
  <text x="453" y="50" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--mono); font-size: 9px;">T+2h</text>
  <text x="580" y="50" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--mono); font-size: 9px;">T+3h</text>
  <text x="707" y="50" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--mono); font-size: 9px;">T+4h</text>

  <!-- Row 1: Normal repeater (healthy) -->
  <text x="20" y="92" style="fill: var(--text); font-family: var(--mono); font-size: 11px;">relay-north</text>
  <text x="20" y="108" style="fill: var(--text-muted); font-family: var(--font); font-size: 10px;">(normal)</text>
  <line x1="200" y1="88" x2="710" y2="88" style="stroke: var(--border-subtle);" stroke-width="1.5" />
  <!-- One advert tick in 4h window: only if interval was 47h, none would appear in 4h -->
  <!-- Show "no adverts in this window" gracefully -->
  <text x="455" y="92" text-anchor="middle" style="fill: var(--text-muted); font-family: var(--font); font-size: 10px; font-style: italic;">— 1 advert per 47 hours (default) —</text>
  <text x="710" y="92" text-anchor="end" style="fill: var(--accent-light); font-family: var(--mono); font-size: 11px; font-weight: 600;">~0.02/h</text>

  <!-- Row 2: Chatty node (problem) -->
  <text x="20" y="148" style="fill: var(--text); font-family: var(--mono); font-size: 11px;">relay-edge</text>
  <text x="20" y="164" style="fill: var(--sys-red-400); font-family: var(--font); font-size: 10px;">(chatty)</text>
  <line x1="200" y1="144" x2="710" y2="144" style="stroke: var(--border-subtle);" stroke-width="1.5" />
  <!-- Dense advert ticks every ~3 mins -->
  <g style="stroke: var(--sys-red-400); stroke-width: 2; opacity: 0.85;">
