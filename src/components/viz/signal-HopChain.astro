---
/**
 * signal-HopChain — four-node linear path (Source → Relay-A → Relay-B → Observer)
 * with per-hop SNR labels. The weakest hop is highlighted in warning color.
 * A callout at the bottom shows the effective path quality = weakest hop.
 * Theme-aware via CSS custom properties.
 */
---

<svg viewBox="0 0 720 214" role="img" aria-label="Three-hop path from Source to Observer via Relay-A and Relay-B. First hop SNR is plus 11 dB, second hop is plus 3 dB (the weakest, highlighted), third hop is plus 9 dB. A callout reads: effective path quality equals plus 3 dB — the weakest hop sets the ceiling." style="width:100%;height:auto;">
  <defs>
    <marker id="shc-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M0 0L10 5L0 10z" style="fill: var(--border-hover);" />
    </marker>
    <marker id="shc-arrow-warn" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M0 0L10 5L0 10z" style="fill: var(--sys-yellow-400);" />
    </marker>
  </defs>

  <!-- ── Kicker ── -->
  <text x="20" y="28" class="viz-label" style="fill: var(--text-accent); letter-spacing:0.06em;">THE WEAKEST HOP</text>

  <!-- ────────────────────────
       Nodes (y=108 center)
       ──────────────────────── -->

  <!-- Source node (circle) -->
  <circle cx="70" cy="108" r="16" style="fill: var(--surface-1); stroke: var(--text-tertiary);" stroke-width="1.75" />
  <text x="70" y="113" text-anchor="middle" class="viz-label" style="fill: var(--text-tertiary); font-size:8px;">SRC</text>
  <text x="70" y="140" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">source</text>

  <!-- Relay-A (square) -->
  <rect x="188" y="90" width="36" height="36" rx="6" style="fill: var(--surface-1); stroke: var(--text-muted);" stroke-width="1.5" />
  <text x="206" y="113" text-anchor="middle" class="viz-label" style="fill: var(--text-muted); font-size:8px;">RLY</text>
  <text x="206" y="140" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">relay-A</text>

  <!-- Relay-B (square) — slightly highlighted to suggest the weak hop arrived here -->
  <rect x="368" y="90" width="36" height="36" rx="6" style="fill: var(--surface-1); stroke: var(--sys-yellow-400);" stroke-width="1.5" stroke-dasharray="3 2" />
  <text x="386" y="113" text-anchor="middle" class="viz-label" style="fill: var(--sys-yellow-400); font-size:8px;">RLY</text>
  <text x="386" y="140" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">relay-B</text>

  <!-- Observer (circle, accent border) -->
  <circle cx="548" cy="108" r="16" style="fill: var(--accent-subtle); stroke: var(--accent-light);" stroke-width="1.75" />
  <text x="548" y="113" text-anchor="middle" class="viz-label" style="fill: var(--accent-light); font-size:8px;">OBS</text>
  <text x="548" y="140" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">observer</text>

  <!-- ────────────────────────
       Hop arrows
       ──────────────────────── -->

  <!-- Hop 1: Source → Relay-A (+11 dB, strong) -->
  <line x1="87" y1="108" x2="187" y2="108" style="stroke: var(--border-hover);" stroke-width="2" marker-end="url(#shc-arrow)" />

  <!-- Hop 2: Relay-A → Relay-B (+3 dB, WEAK — warning color) -->
  <line x1="225" y1="108" x2="367" y2="108" style="stroke: var(--sys-yellow-400);" stroke-width="2" stroke-dasharray="5 3" marker-end="url(#shc-arrow-warn)" />

  <!-- Hop 3: Relay-B → Observer (+9 dB, strong) -->
  <line x1="405" y1="108" x2="531" y2="108" style="stroke: var(--border-hover);" stroke-width="2" marker-end="url(#shc-arrow)" />

  <!-- ────────────────────────
       SNR labels above arrows
       ──────────────────────── -->

  <!-- Hop 1: midpoint ≈ x=137 -->
  <text x="137" y="95" text-anchor="middle" style="font-family: var(--mono); font-size: 12px; font-weight: 600; fill: var(--accent-light);">+11 dB</text>

  <!-- Hop 2: midpoint ≈ x=296 — warning styling -->
  <text x="296" y="89" text-anchor="middle" style="font-family: var(--mono); font-size: 13px; font-weight: 700; fill: var(--sys-yellow-400);">+3 dB</text>
  <!-- Small warning badge -->
  <polygon points="296,72 301,81 291,81" style="fill: var(--sys-yellow-400);" />
  <text x="296" y="69" text-anchor="middle" class="viz-label" style="fill: var(--sys-yellow-400);">WEAKEST</text>

  <!-- Hop 3: midpoint ≈ x=468 -->
  <text x="468" y="95" text-anchor="middle" style="font-family: var(--mono); font-size: 12px; font-weight: 600; fill: var(--accent-light);">+9 dB</text>

  <!-- ────────────────────────
       Callout box (effective path quality)
       ──────────────────────── -->
  <rect x="60" y="162" width="600" height="38" rx="9" style="fill: var(--surface-1); stroke: var(--border-subtle);" stroke-width="1" />
  <text x="360" y="177" text-anchor="middle" class="viz-label" style="fill: var(--text-accent); letter-spacing:0.05em;">EFFECTIVE PATH QUALITY</text>
  <text x="360" y="193" text-anchor="middle" style="font-family: var(--mono); font-size: 13px; font-weight: 600; fill: var(--sys-yellow-400);">= +3 dB</text>
  <text x="440" y="193" text-anchor="start"  style="font-family: var(--mono); font-size: 11px; fill: var(--text-muted);">· the weakest hop sets the ceiling</text>
</svg>
