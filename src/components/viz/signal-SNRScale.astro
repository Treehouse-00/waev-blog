---
/**
 * signal-SNRScale — horizontal SNR zones ruler for MeshCore / LoRa links.
 * Five zones: at-noise-floor · unreliable · marginal · comfortable · strong.
 * All breakpoints are rules of thumb; a footer note says so explicitly.
 * Theme-aware via CSS custom properties.
 */
---

<svg viewBox="0 0 720 205" role="img" aria-label="SNR zones ruler. Five ranges labeled from left to right: at noise floor (below negative 5 dB), unreliable (negative 5 to 0 dB), marginal (0 to plus 7 dB), comfortable (plus 7 to plus 13 dB), and strong (above plus 13 dB). Rules of thumb for MeshCore LoRa links." style="width:100%;height:auto;">
  <defs>
    <clipPath id="snrs-bar-clip">
      <rect x="60" y="54" width="600" height="44" rx="9" />
    </clipPath>
  </defs>

  <!-- ── Kicker ── -->
  <text x="20" y="32" class="viz-label" style="fill: var(--text-accent); letter-spacing:0.06em;">SNR ZONES · RULES OF THUMB</text>

  <!-- ── Zone fills, clipped to rounded bar ── -->
  <g clip-path="url(#snrs-bar-clip)">
    <rect x="60"  y="54" width="100" height="44" style="fill: var(--sys-red-400);"   opacity="0.55" />
    <rect x="160" y="54" width="100" height="44" style="fill: var(--sys-red-400);"   opacity="0.22" />
    <rect x="260" y="54" width="140" height="44" style="fill: var(--sys-yellow-400);" opacity="0.38" />
    <rect x="400" y="54" width="120" height="44" style="fill: var(--accent-light);"  opacity="0.22" />
    <rect x="520" y="54" width="140" height="44" style="fill: var(--accent-light);"  opacity="0.44" />
  </g>

  <!-- ── Bar border + internal dividers ── -->
  <rect x="60" y="54" width="600" height="44" rx="9" fill="none" style="stroke: var(--border-subtle);" stroke-width="1" />
  <line x1="160" y1="54" x2="160" y2="98" style="stroke: var(--border-subtle);" stroke-width="1" />
  <line x1="260" y1="54" x2="260" y2="98" style="stroke: var(--border-subtle);" stroke-width="1" />
  <line x1="400" y1="54" x2="400" y2="98" style="stroke: var(--border-subtle);" stroke-width="1" />
  <line x1="520" y1="54" x2="520" y2="98" style="stroke: var(--border-subtle);" stroke-width="1" />

  <!-- ── Zone labels + dB range inside the bar ── -->
  <text x="110" y="73" text-anchor="middle" class="viz-label" style="fill: var(--sys-red-400);">AT FLOOR</text>
  <text x="110" y="88" text-anchor="middle" class="viz-label" style="fill: var(--text-tertiary); font-size:9px;">≤ −5 dB</text>

  <text x="210" y="73" text-anchor="middle" class="viz-label" style="fill: var(--sys-red-400); opacity:0.75;">UNRELIABLE</text>
  <text x="210" y="88" text-anchor="middle" class="viz-label" style="fill: var(--text-tertiary); font-size:9px;">−5 to 0 dB</text>

  <text x="330" y="73" text-anchor="middle" class="viz-label" style="fill: var(--sys-yellow-400);">MARGINAL</text>
  <text x="330" y="88" text-anchor="middle" class="viz-label" style="fill: var(--text-tertiary); font-size:9px;">0 to +7 dB</text>

  <text x="460" y="73" text-anchor="middle" class="viz-label" style="fill: var(--accent-light);">COMFORTABLE</text>
  <text x="460" y="88" text-anchor="middle" class="viz-label" style="fill: var(--text-tertiary); font-size:9px;">+7 to +13 dB</text>

  <text x="590" y="73" text-anchor="middle" class="viz-label" style="fill: var(--accent-light);">STRONG</text>
  <text x="590" y="88" text-anchor="middle" class="viz-label" style="fill: var(--text-tertiary); font-size:9px;">above +13 dB</text>

  <!-- ── Tick marks at zone boundaries ── -->
  <line x1="160" y1="98" x2="160" y2="108" style="stroke: var(--text-tertiary);" stroke-width="1.5" />
  <line x1="260" y1="98" x2="260" y2="108" style="stroke: var(--text-tertiary);" stroke-width="1.5" />
  <line x1="400" y1="98" x2="400" y2="108" style="stroke: var(--text-tertiary);" stroke-width="1.5" />
  <line x1="520" y1="98" x2="520" y2="108" style="stroke: var(--text-tertiary);" stroke-width="1.5" />

  <!-- Tick labels -->
  <text x="160" y="122" text-anchor="middle" class="viz-label">−5 dB</text>
  <text x="260" y="122" text-anchor="middle" class="viz-label">0 dB</text>
  <text x="400" y="122" text-anchor="middle" class="viz-label">+7 dB</text>
  <text x="520" y="122" text-anchor="middle" class="viz-label">+13 dB</text>

  <!-- ── Zone descriptions ── -->
  <text x="110" y="144" text-anchor="middle" class="viz-label" style="fill: var(--text-tertiary);">LoRa can decode it;</text>
  <text x="110" y="158" text-anchor="middle" class="viz-label" style="fill: var(--text-tertiary);">mesh can't rely on it</text>

  <text x="210" y="144" text-anchor="middle" class="viz-label" style="fill: var(--text-tertiary);">alive in ideal</text>
  <text x="210" y="158" text-anchor="middle" class="viz-label" style="fill: var(--text-tertiary);">conditions only</text>

  <text x="330" y="144" text-anchor="middle" class="viz-label" style="fill: var(--text-tertiary);">weather- and</text>
  <text x="330" y="158" text-anchor="middle" class="viz-label" style="fill: var(--text-tertiary);">terrain-dependent</text>

  <text x="460" y="144" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">reliable under</text>
  <text x="460" y="158" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">most conditions</text>

  <text x="590" y="144" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">dependable;</text>
  <text x="590" y="158" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">not always achievable</text>

  <!-- ── Rules-of-thumb footnote ── -->
  <text x="360" y="196" text-anchor="middle" class="viz-label" style="fill: var(--text-tertiary); font-style:italic;">
    all zones are rules of thumb — terrain, antenna, and spread factor shift where each transition falls in practice
  </text>
</svg>
