---
/**
 * signal-PathMatrix — 2×2 diagnostic quadrant: hop count (few / many) × SNR (strong / weak).
 * Each cell names the condition and gives a one-line action prompt.
 * Color-coded: green (optimal) · yellow (long reach) · orange (RF problem) · red (edge).
 * Theme-aware via CSS custom properties.
 */
---

<svg viewBox="0 0 720 268" role="img" aria-label="Two-by-two path quality matrix. Few hops plus strong SNR: Optimal, maintain baseline. Many hops plus strong SNR: Long reach, watch for hop creep. Few hops plus weak SNR: RF problem, investigate antenna or siting. Many hops plus weak SNR: Edge of coverage, consider a repeater." style="width:100%;height:auto;">

  <!-- ── Kicker ── -->
  <text x="20" y="26" class="viz-label" style="fill: var(--text-accent); letter-spacing:0.06em;">PATH QUALITY AT A GLANCE · RULES OF THUMB</text>

  <!-- ────────────────────────────────────────────────
       Grid: x=30–700 (670px), y=44–252 (208px)
       Cols: 30–365 and 365–700
       Rows: 44–148 and 148–252
       ──────────────────────────────────────────────── -->

  <!-- ── Cell fills ── -->
  <!-- Top-left: Optimal (accent green tint) -->
  <rect x="30"  y="44" width="335" height="104" rx="0" style="fill: var(--accent-light);" opacity="0.10" />
  <!-- Top-right: Long Reach (yellow tint) -->
  <rect x="365" y="44" width="335" height="104" rx="0" style="fill: var(--sys-yellow-400);" opacity="0.10" />
  <!-- Bottom-left: RF Problem (red tint) -->
  <rect x="30"  y="148" width="335" height="104" rx="0" style="fill: var(--sys-red-400);" opacity="0.10" />
  <!-- Bottom-right: Edge of Coverage (red stronger tint) -->
  <rect x="365" y="148" width="335" height="104" rx="0" style="fill: var(--sys-red-400);" opacity="0.18" />

  <!-- ── Grid border ── -->
  <rect x="30" y="44" width="670" height="208" rx="10" fill="none" style="stroke: var(--border-subtle);" stroke-width="1" />

  <!-- ── Internal grid lines ── -->
  <line x1="365" y1="44" x2="365" y2="252" style="stroke: var(--border-subtle);" stroke-width="1" />
  <line x1="30" y1="148" x2="700" y2="148" style="stroke: var(--border-subtle);" stroke-width="1" />

  <!-- ── Column headers (above grid) ── -->
  <text x="197" y="38" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">FEW HOPS  ·  1–3</text>
  <text x="532" y="38" text-anchor="middle" class="viz-label" style="fill: var(--text-muted);">MANY HOPS  ·  4+</text>

  <!-- ── Row headers (left of grid, as tiny labels inside first col) ── -->
  <!-- These are repeated inside cells to keep layout clean -->

  <!-- ────────────────────────
       CELL 1 — top-left: OPTIMAL
       ──────────────────────── -->
  <text x="50" y="70" class="viz-label" style="fill: var(--text-tertiary);">few hops · strong SNR</text>
  <!-- Status badge dot -->
  <circle cx="50" cy="92" r="5" style="fill: var(--accent-light);" />
  <text x="62" y="97" style="font-family: var(--mono); font-size: 14px; font-weight: 700; fill: var(--accent-light);">OPTIMAL</text>
  <text x="50" y="118" class="viz-label" style="fill: var(--text-muted);">Reliable under most conditions.</text>
  <text x="50" y="132" class="viz-label" style="fill: var(--text-muted);">Maintain as your baseline.</text>

  <!-- ────────────────────────
       CELL 2 — top-right: LONG REACH
       ──────────────────────── -->
  <text x="385" y="70" class="viz-label" style="fill: var(--text-tertiary);">many hops · strong SNR</text>
  <circle cx="385" cy="92" r="5" style="fill: var(--sys-yellow-400);" />
  <text x="397" y="97" style="font-family: var(--mono); font-size: 14px; font-weight: 700; fill: var(--sys-yellow-400);">LONG REACH</text>
  <text x="385" y="118" class="viz-label" style="fill: var(--text-muted);">Working path; each hop is sound.</text>
  <text x="385" y="132" class="viz-label" style="fill: var(--text-muted);">Watch for hop-count creep over time.</text>

  <!-- ────────────────────────
       CELL 3 — bottom-left: RF PROBLEM
       ──────────────────────── -->
  <text x="50" y="170" class="viz-label" style="fill: var(--text-tertiary);">few hops · weak SNR</text>
  <circle cx="50" cy="192" r="5" style="fill: var(--sys-red-400);" />
  <text x="62" y="197" style="font-family: var(--mono); font-size: 14px; font-weight: 700; fill: var(--sys-red-400);">RF PROBLEM</text>
  <text x="50" y="218" class="viz-label" style="fill: var(--text-muted);">Short path, poor signal quality.</text>
  <text x="50" y="232" class="viz-label" style="fill: var(--text-muted);">Check antenna, siting, or obstacles.</text>

  <!-- ────────────────────────
       CELL 4 — bottom-right: EDGE OF COVERAGE
       ──────────────────────── -->
  <text x="385" y="170" class="viz-label" style="fill: var(--text-tertiary);">many hops · weak SNR</text>
  <circle cx="385" cy="192" r="5" style="fill: var(--sys-red-400);" />
  <text x="397" y="197" style="font-family: var(--mono); font-size: 13px; font-weight: 700; fill: var(--sys-red-400);">EDGE OF COVERAGE</text>
  <text x="385" y="218" class="viz-label" style="fill: var(--text-muted);">Routing far around a gap on a weak path.</text>
  <text x="385" y="232" class="viz-label" style="fill: var(--text-muted);">Consider a repeater at the midpoint.</text>

  <!-- ── Row axis label (right side) ── -->
  <text x="706" y="101" text-anchor="start" class="viz-label" style="fill: var(--text-tertiary);">STRONG</text>
  <text x="706" y="115" text-anchor="start" class="viz-label" style="fill: var(--text-tertiary);">SNR</text>
  <text x="706" y="127" text-anchor="start" class="viz-label" style="fill: var(--text-tertiary);">&gt; +7 dB</text>

  <text x="706" y="195" text-anchor="start" class="viz-label" style="fill: var(--text-tertiary);">WEAK</text>
  <text x="706" y="209" text-anchor="start" class="viz-label" style="fill: var(--text-tertiary);">SNR</text>
  <text x="706" y="221" text-anchor="start" class="viz-label" style="fill: var(--text-tertiary);">&lt; +5 dB</text>
</svg>
